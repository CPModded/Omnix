<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>OMNIX - Plateforme Officielle</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      background-color: #030712;
      color: #f1f5f9;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      position: relative;
      overflow-x: hidden;
      line-height: 1.5;
    }
    .halo-top { position: absolute; top: -150px; left: -150px; width: 500px; height: 500px; background: rgba(124, 58, 237, 0.06); filter: blur(100px); border-radius: 50%; pointer-events: none; }
    .halo-bottom { position: absolute; bottom: -150px; right: -150px; width: 500px; height: 500px; background: rgba(6, 182, 212, 0.06); filter: blur(100px); border-radius: 50%; pointer-events: none; }
    header {
      border-bottom: 1px solid #1e293b;
      background: rgba(15, 23, 42, 0.7);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      padding: 16px 24px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      position: sticky;
      top: 0;
      z-index: 50;
    }
    .logo-area { display: flex; align-items: center; gap: 12px; text-decoration: none; }
    .logo-img { width: 38px; height: 38px; border-radius: 10px; object-fit: cover; box-shadow: 0 4px 12px rgba(79, 70, 229, 0.3); }
    .logo-text {
      font-weight: 800;
      letter-spacing: 1px;
      background: linear-gradient(to right, #60a5fa, #22d3ee, #a78bfa);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      font-size: 18px;
    }
    .btn-burger { background: none; border: none; color: #94a3b8; cursor: pointer; display: flex; align-items: center; }
    .burger-icon { width: 24px; height: 24px; fill: currentColor; }
    .drawer {
      position: fixed;
      top: 0;
      right: -300px;
      width: 280px;
      height: 100vh;
      background: rgba(15, 23, 42, 0.85);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      border-left: 1px solid rgba(255, 255, 255, 0.04);
      z-index: 1000;
      transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      padding: 32px 24px;
      display: flex;
      flex-direction: column;
      gap: 32px;
    }
    .drawer.open { transform: translateX(-300px); }
    .btn-close-drawer { background: none; border: none; color: #64748b; font-size: 28px; cursor: pointer; }
    .drawer-links { display: flex; flex-direction: column; gap: 16px; }
    .drawer-links a {
      text-decoration: none;
      color: #94a3b8;
      font-size: 13px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1px;
      padding: 12px 16px;
      border-radius: 10px;
      transition: background 0.15s, color 0.15s;
    }
    .drawer-links a:hover { background: rgba(255,255,255,0.02); color: white; }
    .drawer-links a.active { color: #38bdf8; background: rgba(56, 189, 248, 0.05); }

    main {
      flex: 1;
      max-width: 1000px;
      width: 100%;
      margin: 0 auto;
      padding: 60px 24px;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      z-index: 10;
    }
    .tag {
      font-size: 11px;
      font-weight: 800;
      color: #a78bfa;
      background: rgba(124, 58, 237, 0.08);
      border: 1px solid rgba(124, 58, 237, 0.2);
      padding: 6px 14px;
      border-radius: 20px;
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 24px;
      display: inline-block;
    }
    h1 {
      font-size: 38px;
      font-weight: 900;
      line-height: 1.15;
      letter-spacing: -1px;
      color: white;
      margin-bottom: 24px;
      max-width: 800px;
    }
    h1 span {
      background: linear-gradient(to right, #60a5fa, #22d3ee, #a78bfa);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    p.subtitle {
      font-size: 16px;
      color: #94a3b8;
      max-width: 700px;
      line-height: 1.6;
      margin-bottom: 40px;
    }
    .cta-area {
      display: flex;
      flex-direction: column;
      gap: 16px;
      width: 100%;
      max-width: 400px;
      margin-bottom: 60px;
    }
    @media (min-width: 600px) { .cta-area { flex-direction: row; max-width: 500px; } }
    .btn-primary {
      flex: 1;
      padding: 16px 24px;
      background: linear-gradient(135deg, #4f46e5, #7c3aed);
      color: white;
      font-size: 13px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1px;
      text-decoration: none;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
      box-shadow: 0 4px 15px rgba(79, 70, 229, 0.25);
      transition: transform 0.1s, box-shadow 0.15s;
    }
    .btn-primary:hover { box-shadow: 0 6px 20px rgba(79, 70, 229, 0.35); }
    .btn-primary:active { transform: scale(0.98); }
    .btn-secondary {
      flex: 1;
      padding: 16px 24px;
      background: rgba(15, 23, 42, 0.5);
      border: 1px solid #1e293b;
      color: #cbd5e1;
      font-size: 14px;
      font-weight: 600;
      text-decoration: none;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: border-color 0.15s, background 0.15s;
    }
    .btn-secondary:hover { border-color: #334155; background: rgba(15, 23, 42, 0.8); }
    .stats-grid {
      display: grid;
      grid-template-cols: repeat(2, 1fr);
      gap: 16px;
      width: 100%;
      max-width: 800px;
      background: rgba(15, 23, 42, 0.45);
      border: 1px solid rgba(255, 255, 255, 0.03);
      padding: 24px;
      border-radius: 20px;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
    }
    @media (min-width: 768px) { .stats-grid { grid-template-cols: repeat(5, 1fr); } }
    .stat-item { display: flex; flex-direction: column; align-items: center; }
    .stat-num {
      font-size: 28px;
      font-weight: 800;
      background: linear-gradient(to right, #38bdf8, #818cf8);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .stat-label { font-size: 10px; font-weight: 700; color: #64748b; text-transform: uppercase; letter-spacing: 1px; margin-top: 4px; }
    footer { border-top: 1px solid #0f172a; padding: 24px; text-align: center; font-size: 12px; color: #475569; }
    .discord-svg { width: 18px; height: 18px; fill: currentColor; }
  </style>
</head>
<body>

  <div class="halo-top"></div>
  <div class="halo-bottom"></div>

  <!-- En-tête -->
  <header>
    <a href="/" class="logo-area">
      <img src="/logo.png" id="logo-main-img" onerror="this.style.display='none'; document.getElementById('logo-fallback-box').style.display='flex';" class="logo-img" alt="OMNIX Logo">
      <div id="logo-fallback-box" style="display: none; width: 38px; height: 38px; border-radius: 10px; background: linear-gradient(135deg, #06b6d4, #7c3aed); align-items: center; justify-content: center; font-weight: 900; color: white; font-size: 18px; box-shadow: 0 4px 12px rgba(6, 182, 212, 0.2);">O</div>
      <span class="logo-text">OMNIX</span>
    </a>
    
    <button onclick="toggleDrawer(true)" class="btn-burger">
      <svg class="burger-icon" viewBox="0 0 24 24"><path d="M3 18h18v-2H3v2zm0-5h18v-2H3v2zm0-7v2h18V6H3z"/></svg>
    </button>
  </header>

  <!-- MENU TIROIR DE NAVIGATION DROIT -->
  <div id="side-drawer" class="drawer">
    <div class="drawer-header">
      <span class="logo-text">Menu</span>
      <button onclick="toggleDrawer(false)" class="btn-close-drawer">&times;</button>
    </div>
    <div class="drawer-links" id="drawer-nav">
      <a href="/" class="active">Accueil</a>
      <a href="/dashboard">Dashboard</a>
      <a href="/pricing">Abonnements</a>
      <a href="/founder">Découvrir OMNIX</a>
    </div>
  </div>

  <main>
    <span class="tag">Plateforme Intégrée SaaS</span>
    <h1>Gérez votre communauté avec <span>OMNIX</span></h1>
    <p class="subtitle">
      OMNIX n’est pas un simple bot Discord. C’est une plateforme intelligente conçue pour automatiser, protéger et développer votre communauté. Gérez l’intégralité de votre serveur depuis une interface moderne, profitez d’outils avancés de modération, d’une économie complète, d’une IA intégrée et d’un tableau de bord puissant. Rejoignez les milliers de communautés qui font déjà confiance à OMNIX.
    </p>

    <div class="cta-area">
      <a href="https://discord.com/api/oauth2/authorize?client_id=<%= clientId %>&redirect_uri=<%= redirectUri %>&response_type=code&scope=identify+guilds" class="btn-primary">
        <svg class="discord-svg" viewBox="0 0 127.14 96.36">
          <path d="M107.7,8.07A105.15,105.15,0,0,0,77.26,0a77.19,77.19,0,0,0-3.3,6.83A96.67,96.67,0,0,0,53.22,6.83,77.19,77.19,0,0,0,49.88,0,105.15,105.15,0,0,0,19.44,8.07C3.66,31.58-1.86,54.65,1,77.53A105.73,105.73,0,0,0,32,96.36a77.7,77.7,0,0,0,6.63-10.85,68.43,68.43,0,0,1-10.43-5c.87-.64,1.71-1.32,2.51-2a75.4,75.4,0,0,0,72.71,0c.8.71,1.64,1.39,2.51,2a68.17,68.17,0,0,1-10.43,5,78.23,78.23,0,0,0,6.63,10.85,105.73,105.73,0,0,0,31.54-18.83C129,54.65,122.94,31.58,107.7,8.07ZM42.45,65.69C36.18,65.69,31,60,31,53S36.18,40.36,42.45,40.36,53.92,46,53.92,53,48.72,65.69,42.45,65.69Zm42.24,0C78.41,65.69,73.24,60,73.24,53S78.41,40.36,84.69,40.36,96.15,46,96.15,53,91,65.69,84.69,65.69Z"/>
        </svg>
        Entrer dans l'application
      </a>
      <a href="/founder" class="btn-secondary">Découvrir OMNIX</a>
    </div>

    <div class="stats-grid">
      <div class="stat-item">
        <span class="stat-num" id="s-servers">...</span>
        <span class="stat-label">Serveurs</span>
      </div>
      <div class="stat-item">
        <span class="stat-num" id="s-users">...</span>
        <span class="stat-label">Membres</span>
      </div>
      <div class="stat-item">
        <span class="stat-num" id="s-commands">...</span>
        <span class="stat-label">Commandes</span>
      </div>
      <div class="stat-item">
        <span class="stat-num" id="s-uptime">...</span>
        <span class="stat-label">Uptime</span>
      </div>
      <div class="stat-item">
        <span class="stat-num" id="s-latency">...</span>
        <span class="stat-label">Latence</span>
      </div>
    </div>
  </main>

  <footer>
    <p>&copy; 2026 OMNIX. Tous droits réservés.</p>
  </footer>

  <script>
    function toggleDrawer(open) {
      const drawer = document.getElementById('side-drawer');
      if (open) {
        drawer.classList.add('open');
      } else {
        drawer.classList.remove('open');
      }
    }

    function parseJwt(token) {
      if (!token || token === 'null' || token === 'undefined' || !token.includes('.')) return null;
      try {
        const base64Url = token.split('.')[1];
        const base64 = base64Url.replace(/-/g, '+').replace(/_/g, '/');
        const pad = base64.length % 4;
        const paddedBase64 = pad ? base64 + '='.repeat(4 - pad) : base64;
        const rawBinary = window.atob(paddedBase64);
        const bytes = new Uint8Array(rawBinary.length);
        for (let i = 0; i < rawBinary.length; i++) {
          bytes[i] = rawBinary.charCodeAt(i);
        }
        const decoder = new TextDecoder('utf-8');
        return JSON.parse(decoder.decode(bytes));
      } catch (e) {
        return null;
      }
    }

    const jwtToken = localStorage.getItem('jwt_token');
    if (jwtToken) {
      const payload = parseJwt(jwtToken);
      if (payload && payload.isAdmin) {
        const nav = document.getElementById('drawer-nav');
        if (nav && !document.getElementById('nav-admin-link')) {
          const adminLink = document.createElement('a');
          adminLink.href = '/admin';
          adminLink.id = 'nav-admin-link';
          adminLink.className = 'admin-nav-link';
          adminLink.innerText = 'Staff Panel';
          nav.appendChild(adminLink);
        }
      }
    }

    function animateValue(obj, start, end, duration, suffix = '') {
      let startTimestamp = null;
      const step = (timestamp) => {
        if (!startTimestamp) startTimestamp = timestamp;
        const progress = Math.min((timestamp - startTimestamp) / duration, 1);
        obj.innerHTML = Math.floor(progress * (end - start) + start) + suffix;
        if (progress < 1) {
          window.requestAnimationFrame(step);
        }
      };
      window.requestAnimationFrame(step);
    }

    async function loadRealStats() {
      try {
        const response = await fetch('/api/stats');
        if (!response.ok) throw new Error();

        const stats = await response.json();
        const uptimePercentage = 99;

        animateValue(document.getElementById('s-servers'), 0, stats.bot.guildsCount || 0, 1000, '');
        animateValue(document.getElementById('s-users'), 0, stats.database.totalUsers || 0, 1000, '');
        animateValue(document.getElementById('s-commands'), 0, 1420, 1000, '');
        animateValue(document.getElementById('s-uptime'), 0, uptimePercentage, 1000, '%');
        animateValue(document.getElementById('s-latency'), 0, stats.bot.ping || 12, 1000, ' ms');

      } catch (error) {
        console.error("Échec du chargement des statistiques réelles.");
        document.getElementById('s-servers').innerText = "0";
        document.getElementById('s-users').innerText = "0";
        document.getElementById('s-commands').innerText = "0";
        document.getElementById('s-uptime').innerText = "100%";
        document.getElementById('s-latency').innerText = "0 ms";
      }
    }

    window.addEventListener('DOMContentLoaded', loadRealStats);
  </script>
</body>
</html>