function setupDynamicButtons() {
      const jwtToken = getToken();
      const headerArea = document.getElementById('auth-buttons-header');
      const ctaArea = document.getElementById('cta-action-area');
      const loginUrl = `https://discord.com/api/oauth2/authorize?client_id=${clientId}&redirect_uri=${redirectUri}&response_type=code&scope=identify+guilds`;

      if (jwtToken) {
        const payload = parseJwt(jwtToken);
        if (payload) {
          headerArea.innerHTML = `
            <a href="/dashboard" class="btn-nav-login" style="background-color: #059669;">Dashboard</a>
            <button onclick="logout()" class="btn-nav-logout">Déconnexion</button>
          `;
          ctaArea.innerHTML = `
            <a href="/dashboard" class="btn-primary" style="background: linear-gradient(135deg, #059669, #10b981);">Accéder au Dashboard</a>
            <a href="/pricing" class="btn-secondary" style="background: linear-gradient(135deg, #4f46e5, #06b6d4); color: white; border: none; box-shadow: 0 4px 12px rgba(6, 182, 212, 0.25);">S'abonner à OMNIX</a>
          `;
          return;
        }
      }

      headerArea.innerHTML = `
        <a href="${loginUrl}" class="btn-nav-login">Se connecter</a>
      `;
      ctaArea.innerHTML = `
        <a href="${loginUrl}" class="btn-primary">
          <svg class="discord-svg" viewBox="0 0 127.14 96.36"><path d="M107.7,8.07A105.15,105.15,0,0,0,77.26,0a77.19,77.19,0,0,0-3.3,6.83A96.67,96.67,0,0,0,53.22,6.83,77.19,77.19,0,0,0,49.88,0,105.15,105.15,0,0,0,19.44,8.07C3.66,31.58-1.86,54.65,1,77.53A105.73,105.73,0,0,0,32,96.36a77.7,77.7,0,0,0,6.63-10.85,68.43,68.43,0,0,1-10.43-5c.87-.64,1.71-1.32,2.51-2a75.4,75.4,0,0,0,72.71,0c.8.71,1.64,1.39,2.51,2a68.17,68.17,0,0,1-10.43,5,78.23,78.23,0,0,0,6.63,10.85,105.73,105.73,0,0,0,31.54-18.83C129,54.65,122.94,31.58,107.7,8.07ZM42.45,65.69C36.18,65.69,31,60,31,53S36.18,40.36,42.45,40.36,53.92,46,53.92,53,48.72,65.69,42.45,65.69Zm42.24,0C78.41,65.69,73.24,60,73.24,53S78.41,40.36,84.69,40.36,96.15,46,96.15,53,91,65.69,84.69,65.69Z"/></svg>
          Entrer dans l'application
        </a>
        <a href="/pricing" class="btn-secondary" style="background: linear-gradient(135deg, #4f46e5, #06b6d4); color: white; border: none; box-shadow: 0 4px 12px rgba(6, 182, 212, 0.25);">S'abonner à OMNIX</a>
      `;
    }