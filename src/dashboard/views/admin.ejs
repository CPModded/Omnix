<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>OMNIX - Panel Staff</title>
  <style>
    /* Styles CSS natifs - Sans dépendance externe (100% stable sur Safari iOS) */
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }
    body {
      background-color: #030712; /* Slate 950 */
      color: #f1f5f9; /* Slate 100 */
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      position: relative;
      overflow-x: hidden;
      line-height: 1.5;
    }
    
    .halo-top {
      position: absolute;
      top: -150px;
      left: -150px;
      width: 500px;
      height: 500px;
      background: rgba(139, 92, 246, 0.04);
      filter: blur(100px);
      border-radius: 50%;
      pointer-events: none;
    }

    header {
      border-bottom: 1px solid #1e293b;
      background: rgba(15, 23, 42, 0.7);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      padding: 16px 24px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      position: sticky;
      top: 0;
      z-index: 50;
    }
    .logo-area {
      display: flex;
      align-items: center;
      gap: 12px;
      text-decoration: none;
    }
    .logo-img {
      width: 38px;
      height: 38px;
      border-radius: 10px;
      object-fit: cover;
      box-shadow: 0 4px 12px rgba(6, 182, 212, 0.2);
    }
    .logo-text {
      font-weight: 800;
      letter-spacing: 1px;
      background: linear-gradient(to right, #60a5fa, #22d3ee, #a78bfa);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      font-size: 16px;
    }

    /* Menu Tiroir (Drawer) Latéral Droit */
    .btn-burger {
      background: none;
      border: none;
      color: #94a3b8;
      cursor: pointer;
      display: flex;
      align-items: center;
    }
    .burger-icon {
      width: 24px;
      height: 24px;
      fill: currentColor;
    }
    .drawer {
      position: fixed;
      top: 0;
      right: -300px; /* Masqué à l'origine */
      width: 280px;
      height: 100vh;
      background: rgba(15, 23, 42, 0.85);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      border-left: 1px solid rgba(255, 255, 255, 0.04);
      box-shadow: -10px 0 30px rgba(0, 0, 0, 0.5);
      z-index: 1000;
      transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      padding: 32px 24px;
      display: flex;
      flex-direction: column;
      gap: 32px;
    }
    .drawer.open {
      transform: translateX(-300px); /* Glissement */
    }
    .drawer-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .btn-close-drawer {
      background: none;
      border: none;
      color: #64748b;
      font-size: 28px;
      cursor: pointer;
    }
    .btn-close-drawer:hover {
      color: white;
    }
    .drawer-links {
      display: flex;
      flex-direction: column;
      gap: 16px;
    }
    .drawer-links a {
      text-decoration: none;
      color: #94a3b8;
      font-size: 13px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1px;
      padding: 12px 16px;
      border-radius: 10px;
      transition: background 0.15s, color 0.15s;
    }
    .drawer-links a:hover {
      background: rgba(255,255,255,0.02);
      color: white;
    }
    .drawer-links a.active {
      color: #38bdf8;
      background: rgba(56, 189, 248, 0.05);
    }
    .admin-nav-link {
      color: #c084fc !important;
      text-shadow: 0 0 8px rgba(192, 132, 252, 0.4);
    }

    .container {
      flex: 1;
      max-width: 1000px;
      width: 100%;
      margin: 0 auto;
      padding: 40px 24px;
      z-index: 10;
    }

    .monitoring-grid {
      display: grid;
      grid-template-cols: 1fr;
      gap: 20px;
      margin-bottom: 48px;
    }
    @media (min-width: 600px) {
      .monitoring-grid {
        grid-template-cols: repeat(3, 1fr);
      }
    }
    .monitor-card {
      background: rgba(15, 23, 42, 0.45);
      border: 1px solid rgba(255, 255, 255, 0.04);
      padding: 24px;
      border-radius: 20px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }
    .monitor-title {
      font-size: 11px;
      font-weight: 700;
      color: #64748b;
      text-transform: uppercase;
      letter-spacing: 1px;
    }
    .monitor-value {
      font-size: 28px;
      font-weight: 800;
      color: white;
      margin-top: 8px;
    }

    /* Barre de recherche */
    .search-box-container {
      margin-bottom: 24px;
    }
    .search-input {
      width: 100%;
      background-color: #030712;
      border: 1px solid #1e293b;
      border-radius: 12px;
      padding: 14px 20px;
      font-size: 13px;
      color: white;
      transition: border-color 0.15s ease;
    }
    .search-input:focus {
      border-color: #8b5cf6;
      outline: none;
    }

    h3 {
      font-size: 20px;
      font-weight: 900;
      color: white;
      margin-bottom: 16px;
    }
    .user-list {
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .user-row {
      background: rgba(15, 23, 42, 0.45);
      border: 1px solid rgba(255, 255, 255, 0.03);
      border-radius: 16px;
      padding: 16px 20px;
      display: flex;
      flex-direction: column;
      gap: 16px;
      justify-content: space-between;
      align-items: center;
      box-shadow: 0 4px 20px rgba(0,0,0,0.1);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
    }
    @media (min-width: 768px) {
      .user-row {
        flex-direction: row;
        gap: 0;
      }
    }
    .user-meta {
      display: flex;
      align-items: center;
      gap: 16px;
    }
    .user-avatar {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      border: 2px solid #1e293b;
      object-fit: cover;
    }
    .user-details h4 {
      font-size: 15px;
      font-weight: 800;
      color: white;
    }
    .user-details p {
      font-size: 11px;
      color: #475569;
      margin-top: 2px;
    }

    .badges {
      display: flex;
      gap: 6px;
      margin-top: 4px;
    }
    .badge {
      font-size: 8px;
      font-weight: 800;
      padding: 3px 8px;
      border-radius: 4px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .badge-admin {
      color: #38bdf8;
      background: rgba(56, 189, 248, 0.1);
      border: 1px solid rgba(56, 189, 248, 0.15);
    }
    .badge-premium {
      color: #c084fc;
      background: rgba(192, 132, 252, 0.1);
      border: 1px solid rgba(192, 132, 252, 0.15);
    }
    .badge-free {
      color: #94a3b8;
      background: rgba(148, 163, 184, 0.05);
      border: 1px solid rgba(148, 163, 184, 0.1);
    }
    .badge-blacklist {
      color: #ef4444;
      background: rgba(239, 68, 68, 0.1);
      border: 1px solid rgba(239, 68, 68, 0.15);
    }

    /* Contrôles d'actions */
    .controls-group {
      display: flex;
      align-items: center;
      gap: 12px;
    }
    select.duration-select {
      background-color: #030712;
      border: 1px solid #1e293b;
      border-radius: 10px;
      padding: 10px 14px;
      color: white;
      font-size: 11px;
      font-weight: 600;
    }
    .btn-action-premium {
      padding: 10px 18px;
      border: none;
      border-radius: 10px;
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      cursor: pointer;
      transition: background 0.15s, transform 0.1s;
    }
    .btn-give-premium {
      background: linear-gradient(135deg, #06b6d4, #4f46e5);
      color: white;
      box-shadow: 0 4px 10px rgba(6, 182, 212, 0.15);
    }
    .btn-revoke-premium {
      background: rgba(220, 38, 38, 0.15);
      color: #f87171;
      border: 1px solid rgba(220, 38, 38, 0.25);
    }
    .btn-blacklist {
      background: rgba(239, 68, 68, 0.15);
      color: #f87171;
      border: 1px solid rgba(239, 68, 68, 0.2);
    }
    .btn-unblacklist {
      background: rgba(52, 211, 153, 0.15);
      color: #34d399;
      border: 1px solid rgba(52, 211, 153, 0.2);
    }
    .btn-action-premium:active {
      transform: scale(0.97);
    }

    /* Console de logs pour le Staff */
    .debug-console {
      margin-top: 40px;
      padding: 20px;
      background: rgba(15, 23, 42, 0.6);
      border: 1px solid rgba(255, 255, 255, 0.05);
      border-radius: 16px;
      font-family: monospace;
      font-size: 11px;
      color: #38bdf8;
      max-height: 250px;
      overflow-y: auto;
      box-shadow: 0 10px 30px rgba(0,0,0,0.3);
    }
    .log-line {
      margin-bottom: 6px;
      border-bottom: 1px solid rgba(255,255,255,0.02);
      padding-bottom: 4px;
    }
    .log-time {
      color: #64748b;
    }
    .log-error {
      color: #f87171;
    }
    .log-success {
      color: #34d399;
    }
  </style>
</head>
<body>

  <!-- Écouteur global d'erreurs -->
  <script>
    window.onerror = function(message, source, lineno, colno, error) {
      const debugConsole = document.getElementById('debug-container');
      const debugMsg = document.getElementById('debug-msg');
      if (debugConsole && debugMsg) {
        debugConsole.style.display = 'block';
        debugMsg.innerText = `${message} (Ligne ${lineno}:${colno})`;
      }
      return false;
    };
  </script>

  <div class="halo-top"></div>

  <!-- En-tête -->
  <header>
    <a href="/dashboard" class="logo-area">
      <img src="/logo.png" id="logo-main-img" onerror="this.style.display='none'; document.getElementById('logo-fallback-box').style.display='flex';" class="logo-img" alt="OMNIX Logo">
      <div id="logo-fallback-box" style="display: none; width: 38px; height: 38px; border-radius: 10px; background: linear-gradient(135deg, #06b6d4, #7c3aed); align-items: center; justify-content: center; font-weight: 900; color: white; font-size: 18px; box-shadow: 0 4px 12px rgba(6, 182, 212, 0.2);">O</div>
      <span class="logo-text">OMNIX Staff Panel</span>
    </a>
    
    <button onclick="toggleDrawer(true)" class="btn-burger">
      <svg class="burger-icon" viewBox="0 0 24 24"><path d="M3 18h18v-2H3v2zm0-5h18v-2H3v2zm0-7v2h18V6H3z"/></svg>
    </button>
  </header>

  <!-- MENU TIROIR DE NAVIGATION DROIT (Désormais sur toutes les pages) -->
  <div id="side-drawer" class="drawer">
    <div class="drawer-header">
      <span class="logo-text">Menu</span>
      <button onclick="toggleDrawer(false)" class="btn-close-drawer">&times;</button>
    </div>
    <div class="drawer-links" id="drawer-nav">
      <a href="/">Accueil</a>
      <a href="/dashboard">Dashboard</a>
      <a href="/pricing">Abonnements</a>
      <a href="/founder">Founder</a>
    </div>
  </div>

  <!-- Panel Staff -->
  <div class="container">
    
    <!-- 1. Section Surveillance Système (Monitoring) -->
    <section class="monitoring-grid">
      <div class="monitor-card">
        <p class="monitor-title">Membres Inscrits</p>
        <p class="monitor-value" id="stats-total-users">0</p>
      </div>
      <div class="monitor-card">
        <p class="monitor-title">Serveurs OMNIX</p>
        <p class="monitor-value" id="stats-total-guilds">0</p>
      </div>
      <div class="monitor-card">
        <p class="monitor-title">Latence Bot</p>
        <p class="monitor-value" id="stats-ping">0 ms</p>
      </div>
    </section>

    <!-- 2. Section Gestion des Membres Inscrits -->
    <section>
      <h3>Membres Inscrits</h3>
      
      <!-- Champ de recherche interactif de membres -->
      <div class="search-box-container">
        <input type="text" id="user-search-input" oninput="filterUsers()" class="search-input" placeholder="Rechercher par pseudo ou ID...">
      </div>

      <div id="users-container" class="user-list">
        <div style="text-align: center; color: #64748b; padding: 32px 0;">Récupération sécurisée des comptes...</div>
      </div>
    </section>

    <!-- CONSOLE DE LOGS VISUELLE EN TEMPS RÉEL (Réinjectée dans le panel Staff) -->
    <div class="debug-console" id="console-log-box" style="margin-top: 48px;">
      <div style="color: #cbd5e1; font-weight: bold; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 8px; margin-bottom: 10px; display: flex; justify-content: space-between;">
        <span>📝 CONSOLE DE SUIVI OMNIX (STAFF)</span>
        <span style="color: #64748b; font-size: 9px; text-transform: uppercase;">Temps Réel</span>
      </div>
      <div id="log-list"></div>
    </div>

  </div>

  <footer>
    <p>&copy; 2026 OMNIX. Tous droits réservés.</p>
  </footer>

  <script>
    const jwtToken = localStorage.getItem('jwt_token');

    if (!jwtToken) {
      window.location.href = '/';
    }

    // Système de logs visuel de la console Staff
    function addLog(message, type = 'info') {
      const logList = document.getElementById('log-list');
      if (!logList) return;
      const timeStr = new Date().toLocaleTimeString('fr-FR');
      const line = document.createElement('div');
      line.className = 'log-line';
      
      let colorClass = '';
      if (type === 'error') colorClass = 'log-error';
      if (type === 'success') colorClass = 'log-success';

      line.innerHTML = `<span class="log-time">[${timeStr}]</span> <span class="${colorClass}">${message}</span>`;
      logList.appendChild(line);
      
      const box = document.getElementById('console-log-box');
      if (box) box.scrollTop = box.scrollHeight;
    }

    // Gestion de l'affichage du menu tiroir
    function toggleDrawer(open) {
      const drawer = document.getElementById('side-drawer');
      if (open) {
        drawer.classList.add('open');
      } else {
        drawer.classList.remove('open');
      }
    }

    function parseJwt(token) {
      if (!token || token === 'null' || token === 'undefined' || !token.includes('.')) return null;
      try {
        const base64Url = token.split('.')[1];
        const base64 = base64Url.replace(/-/g, '+').replace(/_/g, '/');
        const pad = base64.length % 4;
        const paddedBase64 = pad ? base64 + '='.repeat(4 - pad) : base64;
        const rawBinary = window.atob(paddedBase64);
        const bytes = new Uint8Array(rawBinary.length);
        for (let i = 0; i < rawBinary.length; i++) {
          bytes[i] = rawBinary.charCodeAt(i);
        }
        const decoder = new TextDecoder('utf-8');
        return JSON.parse(decoder.decode(bytes));
      } catch (e) {
        return null;
      }
    }

    function renderDrawerMenu() {
      const payload = parseJwt(jwtToken);
      if (payload && payload.isAdmin) {
        const nav = document.getElementById('drawer-nav');
        if (nav && !document.getElementById('nav-admin-link')) {
          const adminLink = document.createElement('a');
          adminLink.href = '/admin';
          adminLink.id = 'nav-admin-link';
          adminLink.className = 'admin-nav-link active';
          adminLink.innerText = 'Staff Panel';
          nav.appendChild(adminLink);
        }
      }
    }

    function filterUsers() {
      const query = document.getElementById('user-search-input').value.toLowerCase().trim();
      const rows = document.querySelectorAll('.user-row');

      rows.forEach(row => {
        const username = row.getAttribute('data-username');
        const discordId = row.getAttribute('data-discordid');
        
        if (username.includes(query) || discordId.includes(query)) {
          row.style.display = 'flex';
        } else {
          row.style.display = 'none';
        }
      });
    }

    async function loadMonitoring() {
      addLog("Chargement des métriques système...");
      try {
        const response = await fetch('/api/admin/monitoring', {
          headers: { 'Authorization': `Bearer ${jwtToken}` }
        });

        if (!response.ok) throw new Error();

        const stats = await response.json();
        document.getElementById('stats-total-users').innerText = stats.database.totalUsers;
        document.getElementById('stats-total-guilds').innerText = stats.bot.guildsCount;
        document.getElementById('stats-ping').innerText = `${stats.bot.ping} ms`;
        addLog("Métriques système chargées avec succès.", "success");

      } catch (error) {
        addLog("Échec de chargement du monitoring.", "error");
      }
    }

    async function loadUsers() {
      addLog("Récupération de la liste des membres...");
      try {
        const response = await fetch('/api/admin/users', {
          headers: { 'Authorization': `Bearer ${jwtToken}` }
        });

        if (!response.ok) throw new Error();

        const users = await response.json();
        const container = document.getElementById('users-container');
        container.innerHTML = '';

        if (users.length === 0) {
          container.innerHTML = `<div style="text-align: center; color: #64748b; padding: 32px 0;">Aucun utilisateur inscrit.</div>`;
          return;
        }

        users.forEach(user => {
          const row = document.createElement('div');
          row.className = "user-row";
          row.setAttribute('data-username', user.username.toLowerCase());
          row.setAttribute('data-discordid', user.discordId);

          const avatarUrl = user.avatar 
            ? `https://cdn.discordapp.com/avatars/${user.discordId}/${user.avatar}.png` 
            : 'https://cdn.discordapp.com/embed/avatars/0.png';

          let badgesHtml = '';
          if (user.isAdmin) {
            badgesHtml += `<span class="badge badge-admin">Admin</span>`;
          }

          const hasUserPremium = user.licenses && user.licenses.some(lic => lic.status === 'active' && lic.activatedGuildId === null);
          const isUserLifetime = user.licenses && user.licenses.some(lic => lic.status === 'active' && lic.tier === 'lifetime');

          if (isUserLifetime) {
            badgesHtml += `<span class="badge badge-premium">Lifetime</span>`;
          } else if (hasUserPremium) {
            badgesHtml += `<span class="badge badge-premium">Premium User</span>`;
          } else {
            badgesHtml += `<span class="badge badge-free">Free User</span>`;
          }

          if (user.isBlacklisted) {
            badgesHtml += `<span class="badge badge-blacklist">Banni</span>`;
          }

          // CORRECTIF : Onglet 180 Jours ajouté dans le sélecteur d'administration
          let durationSelectorHtml = '';
          if (!hasUserPremium && !user.isBlacklisted) {
            durationSelectorHtml = `
              <select id="duration-${user.discordId}" class="duration-select">
                <option value="30">30 Jours</option>
                <option value="90">90 Jours</option>
                <option value="180">180 Jours</option>
                <option value="365">365 Jours</option>
                <option value="0">À Vie (Lifetime)</option>
              </select>
            `;
          }

          let actionBtnHtml = '';
          if (!user.isBlacklisted) {
            if (hasUserPremium || isUserLifetime) {
              actionBtnHtml = `<button onclick="toggleUserPremium('${user.discordId}', false)" class="btn-action-premium btn-revoke-premium">Retirer Premium</button>`;
            } else {
              actionBtnHtml = `<button onclick="toggleUserPremium('${user.discordId}', true)" class="btn-action-premium btn-give-premium">Donner Premium</button>`;
            }
          }

          let blacklistBtnHtml = '';
          if (user.isBlacklisted) {
            blacklistBtnHtml = `<button onclick="toggleBlacklist('${user.discordId}', false)" class="btn-action-premium btn-unblacklist">Débannir</button>`;
          } else {
            blacklistBtnHtml = `<button onclick="toggleBlacklist('${user.discordId}', true)" class="btn-action-premium btn-blacklist">Blacklister</button>`;
          }

          row.innerHTML = `
            <div class="user-meta">
              <img src="${avatarUrl}" class="user-avatar" alt="Avatar">
              <div class="user-details">
                <h4>${user.username}</h4>
                <p>ID: ${user.discordId}</p>
                <div class="badges">
                  ${badgesHtml}
                </div>
              </div>
            </div>
            <div class="controls-group">
              ${durationSelectorHtml}
              ${actionBtnHtml}
              ${blacklistBtnHtml}
            </div>
          `;
          container.appendChild(row);
        });

        addLog("Liste des membres chargée.", "success");

      } catch (error) {
        addLog("Impossible de charger la liste des membres.", "error");
        alert("Accès refusé. Cette console est réservée au Staff OMNIX.");
        window.location.href = '/dashboard';
      }
    }

    async function toggleUserPremium(discordId, grant) {
      let duration = 30;
      const selector = document.getElementById(`duration-${discordId}`);
      if (selector) {
        duration = parseInt(selector.value, 10);
      }

      const payload = {
        guildId: "USER_LICENSE",
        isPremium: grant,
        tier: duration === 0 ? 'lifetime' : 'premium',
        durationInDays: grant ? duration : 0
      };

      addLog(`Tentative d'ajustement du Premium pour l'ID : ${discordId}...`);

      try {
        const response = await fetch('/api/admin/premium', {
          method: 'POST',
          headers: {
            'Authorization': `Bearer ${jwtToken}`,
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ ...payload, userId: discordId })
        });

        if (!response.ok) {
          const errData = await response.json().catch(() => ({}));
          throw new Error(errData.details || errData.error || `Erreur HTTP ${response.status}`);
        }
        addLog("Droits de l'utilisateur modifiés avec succès.", "success");
        loadUsers();

      } catch (error) {
        addLog(`Échec de modification : ${error.message}`, "error");
        alert("Impossible de modifier les privilèges :\n\n" + error.message);
      }
    }

    async function toggleBlacklist(discordId, blacklist) {
      addLog(`Ajustement du statut de bannissement pour l'ID : ${discordId}...`);
      try {
        const response = await fetch('/api/admin/blacklist', {
          method: 'POST',
          headers: {
            'Authorization': `Bearer ${jwtToken}`,
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ userId: discordId, isBlacklisted: blacklist })
        });

        if (!response.ok) {
          const errData = await response.json().catch(() => ({}));
          throw new Error(errData.details || errData.error || `Erreur HTTP ${response.status}`);
        }
        addLog("Statut de bannissement mis à jour.", "success");
        loadUsers();

      } catch (error) {
        addLog(`Échec de modification : ${error.message}`, "error");
        alert("Échec de la modification du statut de bannissement :\n\n" + error.message);
      }
    }

<!-- CONSOLE INFORMATIQUE DE MONITORING OMNIX (À INSERER DANS ADMIN.EJS) -->
<div id="omnix-terminal" style="width: 100%; max-width: 900px; background: #020617; border: 1px solid #1e293b; border-radius: 12px; margin: 40px auto; box-shadow: 0 10px 40px rgba(0,0,0,0.8); overflow: hidden; text-align: left; font-family: 'Courier New', Courier, monospace; z-index: 50;">
  <div style="background: #0f172a; border-bottom: 1px solid #1e293b; padding: 10px 16px; display: flex; justify-content: space-between; align-items: center;">
    <div style="display: flex; align-items: center; gap: 8px;">
      <span style="width: 10px; height: 10px; border-radius: 50%; background: #ef4444; display: inline-block;"></span>
      <span style="width: 10px; height: 10px; border-radius: 50%; background: #f59e0b; display: inline-block;"></span>
      <span style="width: 10px; height: 10px; border-radius: 50%; background: #10b981; display: inline-block;"></span>
      <span style="color: #64748b; font-size: 11px; font-weight: bold; margin-left: 8px; letter-spacing: 1px;">OMNIX ADMIN CONSOLE v2.4</span>
    </div>
    <span style="color: #38bdf8; font-size: 10px; font-weight: bold;">LIVE TRAFFIC</span>
  </div>
  <div id="terminal-screen" style="padding: 16px; height: 300px; overflow-y: auto; font-size: 12px; color: #a3e635; line-height: 1.5; background: #030712;">
    [SYSTEM] Initialisation de la console d'administration en temps réel...
  </div>
</div>

<script>
  function addTerminalLog(type, message) {
    const screen = document.getElementById('terminal-screen');
    if (!screen) return;
    
    const time = new Date().toLocaleTimeString();
    let color = '#a3e635'; // Vert (INFO)
    let label = 'INFO';
    
    if (type === 'warn') { color = '#f59e0b'; label = 'WARN'; }
    else if (type === 'error') { color = '#ef4444'; label = 'ERROR'; }
    else if (type === 'debug') { color = '#38bdf8'; label = 'DEBUG'; }
    else if (type === 'success') { color = '#10b981'; label = 'SUCCESS'; }
    
    const line = document.createElement('div');
    line.style.color = color;
    line.style.marginBottom = '6px';
    line.innerHTML = `[${time}] [${label}] ${message}`;
    
    screen.appendChild(line);
    screen.scrollTop = screen.scrollHeight;
  }

  // Lance un diagnostic automatique à l'ouverture du Staff Panel
  function runAdminDiagnostic() {
    addTerminalLog('info', "Analyse de vos droits de session en cours...");
    const localToken = localStorage.getItem('jwt_token');
    
    if (localToken) {
      addTerminalLog('success', "Session locale trouvée.");
      try {
        const base64Url = localToken.split('.')[1];
        const base64 = base64Url.replace(/-/g, '+').replace(/_/g, '/');
        const payload = JSON.parse(window.atob(base64));
        addTerminalLog('debug', `Identifié en tant que : @${payload.username} (Admin: ${payload.isAdmin})`);
        
        if (payload.isAdmin) {
          addTerminalLog('success', "Accès accordé : Les privilèges d'administrateur de la plateforme ont été validés.");
        } else {
          addTerminalLog('error', "Accès refusé : Votre session ne contient pas le badge d'administrateur.");
        }
      } catch (e) {
        addTerminalLog('error', "Échec de lecture de votre jeton.");
      }
    } else {
      addTerminalLog('error', "Aucun jeton de session détecté.");
    }
  }

  window.addEventListener('DOMContentLoaded', runAdminDiagnostic);
</script>
    // Initialisation
    renderDrawerMenu();
    loadMonitoring();
    loadUsers();
  </script>
