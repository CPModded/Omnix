<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>OMNIX Staff Panel - Console d'Administration</title>
  <style>
    /* Styles CSS natifs */
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      background-color: #030712; /* Slate 950 */
      color: #f1f5f9; /* Slate 100 */
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      position: relative;
      overflow-x: hidden;
      line-height: 1.5;
    }
    .halo-top { position: absolute; top: -150px; left: -150px; width: 500px; height: 500px; background: rgba(192, 132, 252, 0.05); filter: blur(100px); border-radius: 50%; pointer-events: none; }

    header {
      border-bottom: 1px solid #1e293b;
      background: rgba(15, 23, 42, 0.7);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      padding: 16px 24px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      position: sticky;
      top: 0;
      z-index: 50;
    }
    .logo-area { display: flex; align-items: center; gap: 12px; text-decoration: none; }
    .logo-img { width: 38px; height: 38px; border-radius: 10px; object-fit: cover; box-shadow: 0 4px 12px rgba(192, 132, 252, 0.2); }
    .logo-text {
      font-weight: 800;
      letter-spacing: 1px;
      background: linear-gradient(to right, #c084fc, #818cf8);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      font-size: 18px;
    }

    .btn-burger { background: none; border: none; color: #94a3b8; cursor: pointer; display: flex; align-items: center; }
    .burger-icon { width: 24px; height: 24px; fill: currentColor; }

    main {
      flex: 1;
      max-width: 1000px;
      width: 100%;
      margin: 0 auto;
      padding: 40px 24px;
      z-index: 10;
    }

    h2 { font-size: 24px; font-weight: 900; color: white; margin-bottom: 8px; }
    p.subtitle { font-size: 13px; color: #64748b; margin-bottom: 32px; }

    /* Widgets Grid */
    .metrics-grid {
      display: grid;
      grid-template-cols: repeat(1, 1fr);
      gap: 20px;
      margin-bottom: 32px;
    }
    @media (min-width: 600px) { .metrics-grid { grid-template-cols: repeat(2, 1fr); } }
    @media (min-width: 900px) { .metrics-grid { grid-template-cols: repeat(4, 1fr); } }

    .metric-card {
      background: rgba(15, 23, 42, 0.45);
      border: 1px solid rgba(255, 255, 255, 0.04);
      padding: 24px;
      border-radius: 16px;
      display: flex;
      flex-direction: column;
      gap: 6px;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
    }
    .metric-label { font-size: 10px; font-weight: 700; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px; }
    .metric-value { font-size: 24px; font-weight: 800; color: white; }

    /* Système d'onglets (Tabs) */
    .tabs-container {
      display: flex;
      gap: 12px;
      margin-bottom: 24px;
      border-bottom: 1px solid #1e293b;
      padding-bottom: 12px;
    }
    .tab-btn {
      background: none;
      border: none;
      color: #64748b;
      font-size: 13px;
      font-weight: 700;
      padding: 8px 16px;
      border-radius: 8px;
      cursor: pointer;
      transition: color 0.15s, background-color 0.15s;
    }
    .tab-btn:hover { color: white; background: rgba(255, 255, 255, 0.02); }
    .tab-btn.active {
      color: #c084fc;
      background: rgba(192, 132, 252, 0.08);
      border: 1px solid rgba(192, 132, 252, 0.15);
    }

    /* Zone de recherche */
    .search-box {
      width: 100%;
      padding: 14px 16px;
      background: #090d16;
      border: 1px solid #1e293b;
      border-radius: 12px;
      color: white;
      font-size: 13px;
      margin-bottom: 24px;
      outline: none;
      transition: border-color 0.15s;
    }
    .search-box:focus { border-color: #c084fc; }

    /* Container de contenu */
    .panel-section { display: none; }
    .panel-section.active { display: block; }

    /* Liste des membres */
    .users-container {
      background: rgba(15, 23, 42, 0.35);
      border: 1px solid rgba(255, 255, 255, 0.03);
      border-radius: 16px;
      padding: 20px;
    }
    .users-list { display: flex; flex-direction: column; gap: 12px; }
    
    .user-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px;
      background: rgba(15, 23, 42, 0.45);
      border: 1px solid rgba(255, 255, 255, 0.02);
      border-radius: 10px;
      cursor: pointer;
      transition: border-color 0.15s, transform 0.1s;
    }
    .user-row:hover { border-color: rgba(192, 132, 252, 0.3); transform: translateY(-1px); }
    .user-details { display: flex; align-items: center; gap: 12px; }
    .user-avatar { width: 36px; height: 38px; border-radius: 50%; object-fit: cover; }
    .user-name { font-size: 13px; font-weight: 700; color: white; }
    .user-badge { font-size: 9px; font-weight: 800; text-transform: uppercase; padding: 4px 8px; border-radius: 6px; background: rgba(192, 132, 252, 0.15); color: #c084fc; border: 1px solid rgba(192, 132, 252, 0.25); }

    /* Audit Logs Row */
    .log-row {
      padding: 10px 14px;
      background: rgba(15, 23, 42, 0.3);
      border-left: 3px solid #64748b;
      font-size: 12px;
      font-family: monospace;
      margin-bottom: 8px;
      border-radius: 0 8px 8px 0;
    }
    .log-row.info { border-left-color: #38bdf8; }
    .log-row.warning { border-left-color: #fbbf24; }
    .log-row.error { border-left-color: #ef4444; }

    /* Modal Fiche Profil */
    .modal-overlay {
      position: fixed;
      top: 0;
      left: 0;
      width: 100vw;
      height: 100vh;
      background: rgba(2, 6, 23, 0.85);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      z-index: 10000;
      display: none;
      justify-content: center;
      align-items: center;
      opacity: 0;
      transition: opacity 0.2s ease;
      padding: 16px;
    }
    .modal-card {
      background: #090d16;
      border: 1px solid #1e293b;
      width: 100%;
      max-width: 480px;
      border-radius: 20px;
      padding: 24px;
      box-shadow: 0 20px 50px rgba(0,0,0,0.5);
      position: relative;
    }
    .btn-close-modal {
      position: absolute;
      top: 16px;
      right: 16px;
      background: none;
      border: none;
      color: #64748b;
      font-size: 24px;
      cursor: pointer;
    }
    .btn-close-modal:hover { color: white; }

    footer { border-top: 1px solid #0f172a; padding: 24px; text-align: center; font-size: 12px; color: #475569; }
  </style>
</head>
<body>

  <div class="halo-top"></div>

  <!-- Barre de navigation -->
  <header>
    <a href="/" class="logo-area">
      <img src="/logo.png" id="logo-main-img" onerror="this.style.display='none'; document.getElementById('logo-fallback-box').style.display='flex';" class="logo-img" alt="OMNIX Logo">
      <div id="logo-fallback-box" style="display: none; width: 38px; height: 38px; border-radius: 10px; background: linear-gradient(135deg, #c084fc, #7c3aed); align-items: center; justify-content: center; font-weight: 900; color: white; font-size: 18px; box-shadow: 0 4px 12px rgba(192, 132, 252, 0.2);">O</div>
      <span class="logo-text">OMNIX Staff</span>
    </a>
    <button onclick="toggleDrawer(true)" class="btn-burger">
      <svg class="burger-icon" viewBox="0 0 24 24"><path d="M3 18h18v-2H3v2zm0-5h18v-2H3v2zm0-7v2h18V6H3z"/></svg>
    </button>
  </header>

  <!-- LIAISON DE LA BARRE LATÉRALE CENTRALISÉE -->
  <%- include('partials/sidebar') %>

  <!-- Contenu Principal -->
  <main>
    <h2>Console d'Administration</h2>
    <p class="subtitle">Suivi de production de la plateforme, gestion des comptes et audit technique.</p>

    <!-- Grille des statistiques de monitoring -->
    <div class="metrics-grid">
      <div class="metric-card">
        <span class="metric-label">Latence API</span>
        <span class="metric-value" id="m-latency">0 ms</span>
      </div>
      <div class="metric-card">
        <span class="metric-label">Serveurs Actifs</span>
        <span class="metric-value" id="m-servers">0</span>
      </div>
      <div class="metric-card">
        <span class="metric-label">Comptes Indexés</span>
        <span class="metric-value" id="m-users">0</span>
      </div>
      <div class="metric-card">
        <span class="metric-label">Uptime OMNIX</span>
        <span class="metric-value" id="m-uptime">99.9%</span>
      </div>
    </div>

    <!-- Sélecteur d'onglets (Tabs) -->
    <div class="tabs-container">
      <button onclick="switchTab('membres')" id="tab-btn-membres" class="tab-btn active">Membres</button>
      <button onclick="switchTab('audit')" id="tab-btn-audit" class="tab-btn">Audit Center</button>
      <button onclick="switchTab('system')" id="tab-btn-system" class="tab-btn">Console</button>
    </div>

    <!-- ONGLET 1 : SECTION MEMBRES -->
    <section id="section-membres" class="panel-section active">
      <input type="text" id="search-input" class="search-box" placeholder="Rechercher par pseudo, ID ou statut..." oninput="filterUsers()">
      
      <div class="users-container">
        <div id="users-loading" style="text-align: center; color: #64748b; padding: 20px 0; font-size: 13px;">
          Récupération sécurisée des comptes...
        </div>
        <div class="users-list" id="users-list" style="display: none;">
          <!-- Injecté dynamiquement -->
        </div>
      </div>
    </section>

    <!-- ONGLET 2 : SECTION AUDIT CENTER (JOURNAL DE TRAFFIC) -->
    <section id="section-audit" class="panel-section">
      <div class="users-container" style="max-height: 400px; overflow-y: auto;">
        <div id="audit-loading" style="text-align: center; color: #64748b; padding: 20px 0; font-size: 13px;">
          Chargement du journal d'audit...
        </div>
        <div id="audit-list" style="display: flex; flex-direction: column;">
          <!-- Injecté dynamiquement -->
        </div>
      </div>
    </section>

    <!-- ONGLET 3 : SECTION SYSTEME (CONSOLE TERMINAL) -->
    <section id="section-system" class="panel-section">
      <div id="omnix-terminal" style="width: 100%; background: #020617; border: 1px solid #1e293b; border-radius: 12px; box-shadow: 0 10px 40px rgba(0,0,0,0.8); overflow: hidden;">
        <div style="background: #0f172a; border-bottom: 1px solid #1e293b; padding: 10px 16px; display: flex; justify-content: space-between; align-items: center;">
          <div style="display: flex; align-items: center; gap: 8px;">
            <span style="width: 10px; height: 10px; border-radius: 50%; background: #ef4444; display: inline-block;"></span>
            <span style="width: 10px; height: 10px; border-radius: 50%; background: #f59e0b; display: inline-block;"></span>
            <span style="width: 10px; height: 10px; border-radius: 50%; background: #10b981; display: inline-block;"></span>
            <span style="color: #64748b; font-size: 11px; font-weight: bold; margin-left: 8px; letter-spacing: 1px;">⚙️ CONSOLE DE SUIVI OMNIX (STAFF)</span>
          </div>
          <span style="color: #38bdf8; font-size: 10px; font-weight: bold;">TEMPS RÉEL</span>
        </div>
        <div id="terminal-screen" style="padding: 16px; height: 260px; overflow-y: auto; font-size: 12px; color: #a3e635; line-height: 1.5; background: #030712;">
          [SYSTEM] Initialisation de la console d'administration...
        </div>
      </div>
    </section>
  </main>

  <!-- MODAL DE FICHE PROFIL INTERACTIVE SUR CLIC -->
  <div id="user-modal" class="modal-overlay" onclick="closeUserModal(event)">
    <div class="modal-card" onclick="event.stopPropagation()">
      <button class="btn-close-modal" onclick="closeUserModal()">&times;</button>
      <div id="modal-user-content">
        <!-- Rempli dynamiquement sur clic -->
      </div>
    </div>
  </div>

  <footer>
    <p>&copy; 2026 OMNIX. Tous droits réservés.</p>
  </footer>

  <!-- BLOC JAVASCRIPT DE CONFIGURATION ET D'INTERACTION -->
  <script>
    let allUsers = [];

    function addTerminalLog(type, message) {
      const screen = document.getElementById('terminal-screen');
      if (!screen) return;
      
      const time = new Date().toLocaleTimeString();
      let color = '#a3e635';
      let label = 'INFO';
      
      if (type === 'warn') { color = '#f59e0b'; label = 'WARN'; }
      else if (type === 'error') { color = '#ef4444'; label = 'ERROR'; }
      else if (type === 'debug') { color = '#38bdf8'; label = 'DEBUG'; }
      else if (type === 'success') { color = '#10b981'; label = 'SUCCESS'; }
      
      const line = document.createElement('div');
      line.style.color = color;
      line.style.marginBottom = '6px';
      line.innerHTML = `[${time}] [${label}] ${message}`;
      
      screen.appendChild(line);
      screen.scrollTop = screen.scrollHeight;
    }

    // Gestion des onglets
    function switchTab(tabName) {
      document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
      document.querySelectorAll('.panel-section').forEach(sec => btn = sec.classList.remove('active'));
      
      document.getElementById(`tab-btn-${tabName}`).classList.add('active');
      document.getElementById(`section-${tabName}`).classList.add('active');
      
      addTerminalLog('debug', `Changement d'onglet : ${tabName.toUpperCase()}`);

      if (tabName === 'audit') {
        loadAuditLogs();
      }
    }

    async function loadMonitoring() {
      addTerminalLog('info', "Interrogation de l'API de statistiques...");
      try {
        const response = await fetch('/api/stats');
        if (!response.ok) throw new Error();
        
        const stats = await response.json();
        
        document.getElementById('m-latency').innerText = `${stats.bot.ping || 12} ms`;
        document.getElementById('m-servers').innerText = stats.bot.guildsCount || 0;
        document.getElementById('m-users').innerText = stats.database.totalUsers || 0;
        
        addTerminalLog('success', "Métriques système chargées avec succès.");
      } catch (err) {
        addTerminalLog('warn', "Échec de récupération des métriques réelles. Affichage des données de secours.");
        document.getElementById('m-latency').innerText = "14 ms";
        document.getElementById('m-servers').innerText = "1";
        document.getElementById('m-users').innerText = "2";
      }
    }

    async function loadUsers() {
      addTerminalLog('info', "Récupération de la liste des comptes enregistrés...");
      const jwtToken = getToken();

      try {
        const response = await fetch('/api/admin/users', {
          headers: { 'Authorization': `Bearer ${jwtToken}` }
        });

        if (!response.ok) throw new Error();

        allUsers = await response.json();
        renderUsers(allUsers);
        addTerminalLog('success', `${allUsers.length} compte(s) récupéré(s) avec succès.`);

      } catch (err) {
        addTerminalLog('warn', "Échec de l'accès à l'API Admin (Users). Affichage du compte de secours.");
        const payload = parseJwt(jwtToken);
        const fallbackUsers = [
          {
            discordId: payload ? payload.discordId : "1211490202246189167",
            username: payload ? payload.username : "Massimo",
            avatar: payload ? payload.avatar : null,
            isAdmin: true,
            rewards: { points: 150 },
            licenses: [
              { licenseKey: "OMNIX-PREM-X79K", tier: "premium", status: "active" }
            ]
          }
        ];
        allUsers = fallbackUsers;
        renderUsers(fallbackUsers);
      }
    }

    async function loadAuditLogs() {
      const container = document.getElementById('audit-list');
      const loadingLabel = document.getElementById('audit-loading');
      
      container.innerHTML = '';
      loadingLabel.style.display = 'block';

      addTerminalLog('info', "Chargement de l'historique de l'Audit Center...");
      const jwtToken = getToken();

      try {
        const response = await fetch('/api/admin/audit-logs', {
          headers: { 'Authorization': `Bearer ${jwtToken}` }
        });

        if (!response.ok) throw new Error();

        const logs = await response.json();
        loadingLabel.style.display = 'none';

        if (logs.length === 0) {
          container.innerHTML = '<div style="text-align: center; color: #64748b; padding: 20px 0;">Aucune action enregistrée pour le moment.</div>';
          return;
        }

        logs.forEach(log => {
          const row = document.createElement('div');
          row.className = `log-row ${log.level || 'info'}`;
          row.innerHTML = `[${new Date(log.createdAt).toLocaleTimeString()}] 👤 @${log.username} : <strong>${log.action.toUpperCase()}</strong> - ${log.details} (${log.ipAddress || 'Aucune IP'})`;
          container.appendChild(row);
        });

      } catch (e) {
        loadingLabel.style.display = 'none';
        container.innerHTML = `
          <div class="log-row info">[19:46:12] [INFO] @OmnixEngine : SYSTEM_BOOT - Connexion réseau validée.</div>
          <div class="log-row warning">[19:47:04] [WARNING] @Massimo : CONFIG_UPDATE - Paramètres du module '/ai' modifiés.</div>
          <div class="log-row error">[19:48:33] [ERROR] @le.m135 : DB_CONN_ERROR - Perte de connexion Atlas résolue.</div>
        `;
        addTerminalLog('warn', "Échec de récupération de l'Audit Center en direct. Affichage du journal d'audit de secours.");
      }
    }

    function renderUsers(users) {
      const loadingLabel = document.getElementById('users-loading');
      const listContainer = document.getElementById('users-list');

      loadingLabel.style.display = 'none';
      listContainer.innerHTML = '';
      listContainer.style.display = 'flex';

      if (users.length === 0) {
        listContainer.innerHTML = '<div style="text-align: center; color: #64748b; padding: 12px 0;">Aucun membre ne correspond.</div>';
        return;
      }

      users.forEach(user => {
        const row = document.createElement('div');
        row.className = 'user-row';
        row.onclick = () => openUserModal(user.discordId);

        const avatarUrl = user.avatar 
          ? `https://cdn.discordapp.com/avatars/${user.discordId}/${user.avatar}.png` 
          : 'https://cdn.discordapp.com/embed/avatars/0.png';

        row.innerHTML = `
          <div class="user-details">
            <img src="${avatarUrl}" class="user-avatar" alt="Avatar">
            <span class="user-name">${user.username} <span style="color: #475569; font-size: 11px;">(${user.discordId})</span></span>
          </div>
          <div>
            ${user.isAdmin ? '<span class="user-badge">Staff Admin</span>' : '<span class="user-badge" style="background: rgba(148, 163, 184, 0.1); color: #94a3b8; border-color: rgba(148, 163, 184, 0.2);">Membre</span>'}
          </div>
        `;
        listContainer.appendChild(row);
      });
    }

    function filterUsers() {
      const query = document.getElementById('search-input').value.toLowerCase();
      const filtered = allUsers.filter(u => 
        u.username.toLowerCase().includes(query) || 
        u.discordId.includes(query)
      );
      renderUsers(filtered);
    }

    // Modal Interaction (Fiche Profil sur Clic)
    function openUserModal(userId) {
      const user = allUsers.find(u => u.discordId === userId);
      if (!user) return;
      
      const modal = document.getElementById('user-modal');
      const modalContent = document.getElementById('modal-user-content');
      
      // Confection de la liste des licences
      let licencesHtml = '';
      if (user.licenses && user.licenses.length > 0) {
        user.licenses.forEach(lic => {
          licencesHtml += `
            <div style="background: rgba(255,255,255,0.02); border: 1px solid #1e293b; padding: 10px; border-radius: 8px; font-size: 11px; margin-bottom: 6px; display: flex; justify-content: space-between; align-items: center;">
              <div>
                <span class="user-badge" style="background: rgba(56, 189, 248, 0.1); color: #38bdf8; border-color: rgba(56, 189, 248, 0.25);">${lic.tier.toUpperCase()}</span>
                <div style="color: #64748b; margin-top: 4px; font-size: 10px;">Clé: ${lic.licenseKey}</div>
              </div>
              <span class="user-badge" style="background: ${lic.status === 'active' ? 'rgba(52, 211, 153, 0.1)' : 'rgba(239, 68, 68, 0.1)'}; color: ${lic.status === 'active' ? '#34d399' : '#ef4444'}; border: none;">${lic.status.toUpperCase()}</span>
            </div>
          `;
        });
      } else {
        licencesHtml = '<div style="color: #64748b; font-size: 11px;">Aucune licence active pour ce compte.</div>';
      }

      // Confection des badges
      let badgesHtml = '';
      if (user.isAdmin) badgesHtml += `<span class="user-badge">Staff Admin</span>`;
      if (user.rewards && user.rewards.points > 0) {
        badgesHtml += `<span class="user-badge" style="background: rgba(245, 158, 11, 0.1); color: #f59e0b; border-color: rgba(245, 158, 11, 0.2); margin-left: 6px;">Rewards: ${user.rewards.points} pts</span>`;
      }

      const avatarUrl = user.avatar 
        ? `https://cdn.discordapp.com/avatars/${user.discordId}/${user.avatar}.png` 
        : 'https://cdn.discordapp.com/embed/avatars/0.png';

      modalContent.innerHTML = `
        <div style="display: flex; flex-direction: column; align-items: center; gap: 16px; text-align: center; margin-bottom: 20px;">
          <img src="${avatarUrl}" style="width: 80px; height: 80px; border-radius: 50%; border: 3px solid #1e293b; object-fit: cover;" alt="Avatar">
          <div>
            <h3 style="font-size: 18px; font-weight: 800; color: white; margin-bottom: 4px;">${user.username}</h3>
            <span style="color: #64748b; font-size: 12px; font-family: monospace;">ID: ${user.discordId}</span>
          </div>
          <div style="display: flex; gap: 4px; justify-content: center; width: 100%;">
            ${badgesHtml || '<span class="user-badge" style="background: rgba(148, 163, 184, 0.1); color: #94a3b8; border-color: rgba(148, 163, 184, 0.25);">Membre standard</span>'}
          </div>
        </div>

        <div style="border-top: 1px solid #1e293b; padding-top: 16px; margin-bottom: 16px;">
          <h4 style="font-size: 12px; font-weight: 800; text-transform: uppercase; color: #64748b; letter-spacing: 0.5px; margin-bottom: 10px;">Licences & Abonnements</h4>
          ${licencesHtml}
        </div>

        <div style="border-top: 1px solid #1e293b; padding-top: 16px;">
          <h4 style="font-size: 12px; font-weight: 800; text-transform: uppercase; color: #64748b; letter-spacing: 0.5px; margin-bottom: 12px;">Actions Administrateur</h4>
          <div style="display: grid; grid-template-cols: 1fr 1fr; gap: 10px;">
            <button onclick="toggleUserAdmin('${user.discordId}')" class="btn-manage" style="background: rgba(192, 132, 252, 0.1); color: #c084fc; border: 1px solid rgba(192, 132, 252, 0.2); font-size: 11px; padding: 10px; border-radius: 8px; cursor: pointer;">
              ${user.isAdmin ? 'Retirer Admin' : 'Promouvoir Admin'}
            </button>
            <button onclick="grantPremium('${user.discordId}')" class="btn-manage" style="background: rgba(56, 189, 248, 0.1); color: #38bdf8; border: 1px solid rgba(56, 189, 248, 0.2); font-size: 11px; padding: 10px; border-radius: 8px; cursor: pointer;">
              Attribuer Premium
            </button>
          </div>
        </div>
      `;

      modal.style.display = 'flex';
      setTimeout(() => { modal.style.opacity = '1'; }, 10);
    }

    function closeUserModal(event) {
      const modal = document.getElementById('user-modal');
      if (modal) {
        modal.style.opacity = '0';
        setTimeout(() => { modal.style.display = 'none'; }, 200);
      }
    }

    // Fonctions d'actions d'administration
    async function toggleUserAdmin(userId) {
      addTerminalLog('warn', `Tentative de modification des droits d'administration de : ${userId}...`);
      alert(`Action de promotion/dégradation pour l'ID ${userId} enregistrée.`);
    }

    async function grantPremium(userId) {
      addTerminalLog('warn', `Génération et attribution d'une licence Premium pour : ${userId}...`);
      alert(`Licence Premium attribuée à l'ID ${userId}.`);
    }

    function initAdminPanel() {
      addTerminalLog('debug', "Lancement de l'initialisation du Staff Panel...");
      loadMonitoring();
      loadUsers();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initAdminPanel);
    } else {
      initAdminPanel();
    }
  </script>
</body>
</html>