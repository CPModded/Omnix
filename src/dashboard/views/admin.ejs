<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>OMNIX Staff Panel - Console d'Administration</title>
  <style>
    /* Styles CSS natifs */
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      background-color: #030712; /* Slate 950 */
      color: #f1f5f9; /* Slate 100 */
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      position: relative;
      overflow-x: hidden;
      line-height: 1.5;
    }
    .halo-top { position: absolute; top: -150px; left: -150px; width: 500px; height: 500px; background: rgba(192, 132, 252, 0.05); filter: blur(100px); border-radius: 50%; pointer-events: none; }

    header {
      border-bottom: 1px solid #1e293b;
      background: rgba(15, 23, 42, 0.7);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      padding: 16px 24px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      position: sticky;
      top: 0;
      z-index: 50;
    }
    .logo-area { display: flex; align-items: center; gap: 12px; text-decoration: none; }
    .logo-img { width: 38px; height: 38px; border-radius: 10px; object-fit: cover; box-shadow: 0 4px 12px rgba(192, 132, 252, 0.2); }
    .logo-text {
      font-weight: 800;
      letter-spacing: 1px;
      background: linear-gradient(to right, #c084fc, #818cf8);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      font-size: 18px;
    }

    /* Menu Tiroir (Drawer) Latéral Droit */
    .btn-burger { background: none; border: none; color: #94a3b8; cursor: pointer; display: flex; align-items: center; }
    .burger-icon { width: 24px; height: 24px; fill: currentColor; }

    main {
      flex: 1;
      max-width: 1000px;
      width: 100%;
      margin: 0 auto;
      padding: 40px 24px;
      z-index: 10;
    }

    h2 { font-size: 24px; font-weight: 900; color: white; margin-bottom: 8px; }
    p.subtitle { font-size: 13px; color: #64748b; margin-bottom: 32px; }

    /* Widgets Grid */
    .metrics-grid {
      display: grid;
      grid-template-cols: repeat(1, 1fr);
      gap: 20px;
      margin-bottom: 32px;
    }
    @media (min-width: 600px) {
      .metrics-grid { grid-template-cols: repeat(2, 1fr); }
    }
    @media (min-width: 900px) {
      .metrics-grid { grid-template-cols: repeat(4, 1fr); }
    }

    .metric-card {
      background: rgba(15, 23, 42, 0.45);
      border: 1px solid rgba(255, 255, 255, 0.04);
      padding: 24px;
      border-radius: 16px;
      display: flex;
      flex-direction: column;
      gap: 6px;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
    }
    .metric-label { font-size: 10px; font-weight: 700; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px; }
    .metric-value { font-size: 24px; font-weight: 800; color: white; }

    /* Zone de recherche */
    .search-box {
      width: 100%;
      padding: 14px 16px;
      background: #090d16;
      border: 1px solid #1e293b;
      border-radius: 12px;
      color: white;
      font-size: 13px;
      margin-bottom: 24px;
      outline: none;
      transition: border-color 0.15s;
    }
    .search-box:focus { border-color: #c084fc; }

    /* Liste des membres */
    .users-container {
      background: rgba(15, 23, 42, 0.35);
      border: 1px solid rgba(255, 255, 255, 0.03);
      border-radius: 16px;
      padding: 20px;
      margin-bottom: 40px;
    }
    .users-list {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .user-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px;
      background: rgba(15, 23, 42, 0.45);
      border: 1px solid rgba(255, 255, 255, 0.02);
      border-radius: 10px;
    }
    .user-details { display: flex; align-items: center; gap: 12px; }
    .user-avatar { width: 36px; height: 38px; border-radius: 50%; object-fit: cover; }
    .user-name { font-size: 13px; font-weight: 700; color: white; }
    .user-badge { font-size: 9px; font-weight: 800; text-transform: uppercase; padding: 4px 8px; border-radius: 6px; background: rgba(192, 132, 252, 0.15); color: #c084fc; border: 1px solid rgba(192, 132, 252, 0.25); }

    footer { border-top: 1px solid #0f172a; padding: 24px; text-align: center; font-size: 12px; color: #475569; }
  </style>
</head>
<body>

  <div class="halo-top"></div>

  <!-- Barre de navigation -->
  <header>
    <a href="/" class="logo-area">
      <img src="/logo.png" id="logo-main-img" onerror="this.style.display='none'; document.getElementById('logo-fallback-box').style.display='flex';" class="logo-img" alt="OMNIX Logo">
      <div id="logo-fallback-box" style="display: none; width: 38px; height: 38px; border-radius: 10px; background: linear-gradient(135deg, #c084fc, #7c3aed); align-items: center; justify-content: center; font-weight: 900; color: white; font-size: 18px; box-shadow: 0 4px 12px rgba(192, 132, 252, 0.2);">O</div>
      <span class="logo-text">OMNIX Staff</span>
    </a>
    
    <button onclick="toggleDrawer(true)" class="btn-burger">
      <svg class="burger-icon" viewBox="0 0 24 24"><path d="M3 18h18v-2H3v2zm0-5h18v-2H3v2zm0-7v2h18V6H3z"/></svg>
    </button>
  </header>

  <!-- LIAISON DE LA BARRE LATÉRALE CENTRALISÉE -->
  <%- include('partials/sidebar') %>

  <!-- Contenu Principal -->
  <main>
    <h2>Console d'Administration</h2>
    <p class="subtitle">Suivi de production de la plateforme, gestion des comptes et audit technique.</p>

    <!-- Grille des statistiques de monitoring -->
    <div class="metrics-grid">
      <div class="metric-card">
        <span class="metric-label">Latence API</span>
        <span class="metric-value" id="m-latency">0 ms</span>
      </div>
      <div class="metric-card">
        <span class="metric-label">Serveurs Actifs</span>
        <span class="metric-value" id="m-servers">0</span>
      </div>
      <div class="metric-card">
        <span class="metric-label">Comptes Indexés</span>
        <span class="metric-value" id="m-users">0</span>
      </div>
      <div class="metric-card">
        <span class="metric-label">Uptime OMNIX</span>
        <span class="metric-value" id="m-uptime">99.9%</span>
      </div>
    </div>

    <!-- Gestion des comptes -->
    <h2>Membres Inscrits</h2>
    <input type="text" id="search-input" class="search-box" placeholder="Rechercher par pseudo ou ID..." oninput="filterUsers()">
    
    <div class="users-container">
      <div id="users-loading" style="text-align: center; color: #64748b; padding: 20px 0; font-size: 13px;">
        Récupération sécurisée des comptes...
      </div>
      <div class="users-list" id="users-list" style="display: none;">
        <!-- Injecté dynamiquement -->
      </div>
    </div>

    <!-- CONSOLE INFORMATIQUE DE MONITORING OMNIX -->
    <div id="omnix-terminal" style="width: 100%; background: #020617; border: 1px solid #1e293b; border-radius: 12px; box-shadow: 0 10px 40px rgba(0,0,0,0.8); overflow: hidden; text-align: left; font-family: 'Courier New', Courier, monospace;">
      <div style="background: #0f172a; border-bottom: 1px solid #1e293b; padding: 10px 16px; display: flex; justify-content: space-between; align-items: center;">
        <div style="display: flex; align-items: center; gap: 8px;">
          <span style="width: 10px; height: 10px; border-radius: 50%; background: #ef4444; display: inline-block;"></span>
          <span style="width: 10px; height: 10px; border-radius: 50%; background: #f59e0b; display: inline-block;"></span>
          <span style="width: 10px; height: 10px; border-radius: 50%; background: #10b981; display: inline-block;"></span>
          <span style="color: #64748b; font-size: 11px; font-weight: bold; margin-left: 8px; letter-spacing: 1px;">⚙️ CONSOLE DE SUIVI OMNIX (STAFF)</span>
        </div>
        <span style="color: #38bdf8; font-size: 10px; font-weight: bold;">TEMPS RÉEL</span>
      </div>
      <div id="terminal-screen" style="padding: 16px; height: 200px; overflow-y: auto; font-size: 12px; color: #a3e635; line-height: 1.5; background: #030712;">
        [SYSTEM] Initialisation de la console d'administration...
      </div>
    </div>
  </main>

  <footer>
    <p>&copy; 2026 OMNIX. Tous droits réservés.</p>
  </footer>

  <!-- BLOC D'INITIALISATION JAVASCRIPT CORRIGÉ -->
  <script>
    let allUsers = [];

    function addTerminalLog(type, message) {
      const screen = document.getElementById('terminal-screen');
      if (!screen) return;
      
      const time = new Date().toLocaleTimeString();
      let color = '#a3e635';
      let label = 'INFO';
      
      if (type === 'warn') { color = '#f59e0b'; label = 'WARN'; }
      else if (type === 'error') { color = '#ef4444'; label = 'ERROR'; }
      else if (type === 'debug') { color = '#38bdf8'; label = 'DEBUG'; }
      else if (type === 'success') { color = '#10b981'; label = 'SUCCESS'; }
      
      const line = document.createElement('div');
      line.style.color = color;
      line.style.marginBottom = '6px';
      line.innerHTML = `[${time}] [${label}] ${message}`;
      
      screen.appendChild(line);
      screen.scrollTop = screen.scrollHeight;
    }

    async function loadMonitoring() {
      addTerminalLog('info', "Interrogation de l'API de statistiques...");
      try {
        const response = await fetch('/api/stats');
        if (!response.ok) throw new Error("Réponse de l'API non-conforme");
        
        const stats = await response.json();
        
        document.getElementById('m-latency').innerText = `${stats.bot.ping || 12} ms`;
        document.getElementById('m-servers').innerText = stats.bot.guildsCount || 0;
        document.getElementById('m-users').innerText = stats.database.totalUsers || 0;
        
        addTerminalLog('success', "Métriques système chargées avec succès.");
      } catch (err) {
        addTerminalLog('warn', "Échec de récupération des métriques réelles de l'API. Chargement des données d'affichage de secours.");
        document.getElementById('m-latency').innerText = "14 ms";
        document.getElementById('m-servers').innerText = "1";
        document.getElementById('m-users').innerText = "2";
      }
    }

    async function loadUsers() {
      addTerminalLog('info', "Récupération de la liste des comptes enregistrés...");
      const jwtToken = getToken();

      try {
        const response = await fetch('/api/admin/users', {
          headers: { 'Authorization': `Bearer ${jwtToken}` }
        });

        if (!response.ok) throw new Error();

        allUsers = await response.json();
        renderUsers(allUsers);
        addTerminalLog('success', `${allUsers.length} compte(s) récupéré(s) avec succès.`);

      } catch (err) {
        addTerminalLog('warn', "Échec de l'accès à l'API Admin. Affichage du compte de secours.");
        
        // Données de secours pour éviter le blocage de la page
        const payload = parseJwt(jwtToken);
        const fallbackUsers = [
          {
            discordId: payload ? payload.discordId : "1211490202246189167",
            username: payload ? payload.username : "Massimo",
            avatar: payload ? payload.avatar : null,
            isAdmin: true
          }
        ];
        allUsers = fallbackUsers;
        renderUsers(fallbackUsers);
      }
    }

    function renderUsers(users) {
      const loadingLabel = document.getElementById('users-loading');
      const listContainer = document.getElementById('users-list');

      loadingLabel.style.display = 'none';
      listContainer.innerHTML = '';
      listContainer.style.display = 'flex';

      if (users.length === 0) {
        listContainer.innerHTML = '<div style="text-align: center; color: #64748b; padding: 12px 0;">Aucun membre ne correspond à cette recherche.</div>';
        return;
      }

      users.forEach(user => {
        const row = document.createElement('div');
        row.className = 'user-row';

        const avatarUrl = user.avatar 
          ? `https://cdn.discordapp.com/avatars/${user.discordId}/${user.avatar}.png` 
          : 'https://cdn.discordapp.com/embed/avatars/0.png';

        row.innerHTML = `
          <div class="user-details">
            <img src="${avatarUrl}" class="user-avatar" alt="Avatar">
            <span class="user-name">${user.username} <span style="color: #475569; font-size: 11px;">(${user.discordId})</span></span>
          </div>
          <div>
            ${user.isAdmin ? '<span class="user-badge">Staff Admin</span>' : '<span class="user-badge" style="background: rgba(148, 163, 184, 0.1); color: #94a3b8; border-color: rgba(148, 163, 184, 0.2);">Membre</span>'}
          </div>
        `;
        listContainer.appendChild(row);
      });
    }

    function filterUsers() {
      const query = document.getElementById('search-input').value.toLowerCase();
      const filtered = allUsers.filter(u => 
        u.username.toLowerCase().includes(query) || 
        u.discordId.includes(query)
      );
      renderUsers(filtered);
    }

    // Lancement coordonné du tableau d'administration
    function initAdminPanel() {
      addTerminalLog('debug', "Lancement de l'initialisation du Staff Panel...");
      loadMonitoring();
      loadUsers();
    }

    // Exécution propre
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initAdminPanel);
    } else {
      initAdminPanel();
    }
  </script>
</body>
</html>