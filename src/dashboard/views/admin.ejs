// Fonction d'action : Attribution ou Révocation du Premium utilisateur (Diagnostic)
    async function toggleUserPremium(discordId, grant) {
      const payload = {
        guildId: "USER_LICENSE",
        isPremium: grant,
        tier: grant ? 'premium' : 'free',
        durationInDays: grant ? 365 : 0
      };

      try {
        const response = await fetch('/api/admin/premium', {
          method: 'POST',
          headers: {
            'Authorization': `Bearer ${jwtToken}`,
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ ...payload, userId: discordId })
        });

        if (!response.ok) {
          // On capture l'erreur JSON envoyée par l'API
          const errData = await response.json().catch(() => ({}));
          throw new Error(errData.details || errData.error || `Erreur HTTP ${response.status}`);
        }

        // Rechargement des données de l'interface
        loadUsers();

      } catch (error) {
        // Affiche l'erreur exacte sur votre iPhone
        alert("Impossible de modifier les privilèges :\n\n" + error.message);
      }
    }