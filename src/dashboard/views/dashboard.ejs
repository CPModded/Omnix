<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>OMNIX - Vos Serveurs</title>
  <style>
    /* Styles CSS natifs - Sans dépendance externe (100% stable sur Safari iOS) */
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }
    body {
      background-color: #030712; /* Slate 950 */
      color: #f1f5f9; /* Slate 100 */
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      position: relative;
      overflow-x: hidden;
      line-height: 1.5;
    }
    
    .halo-top {
      position: absolute;
      top: -200px;
      right: -200px;
      width: 500px;
      height: 500px;
      background: rgba(6, 182, 212, 0.05); /* Cyan */
      filter: blur(100px);
      border-radius: 50%;
      pointer-events: none;
    }

    /* En-tête */
    header {
      border-bottom: 1px solid #1e293b;
      background: rgba(15, 23, 42, 0.7);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      padding: 16px 24px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      position: sticky;
      top: 0;
      z-index: 50;
    }
    .logo-area {
      display: flex;
      align-items: center;
      gap: 12px;
      text-decoration: none;
    }
    .logo-img {
      width: 38px;
      height: 38px;
      border-radius: 10px;
      object-fit: cover;
      box-shadow: 0 4px 12px rgba(6, 182, 212, 0.2);
    }
    .logo-text {
      font-weight: 800;
      letter-spacing: 1px;
      background: linear-gradient(to right, #22d3ee, #818cf8);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      font-size: 16px;
    }

    /* Menu Tiroir (Drawer) Latéral Droit */
    .btn-burger {
      background: none;
      border: none;
      color: #94a3b8;
      cursor: pointer;
      display: flex;
      align-items: center;
    }
    .burger-icon {
      width: 24px;
      height: 24px;
      fill: currentColor;
    }
    .drawer {
      position: fixed;
      top: 0;
      right: -300px; /* Masqué à l'origine */
      width: 280px;
      height: 100vh;
      background: rgba(15, 23, 42, 0.85);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      border-left: 1px solid rgba(255, 255, 255, 0.04);
      box-shadow: -10px 0 30px rgba(0, 0, 0, 0.5);
      z-index: 1000;
      transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      padding: 32px 24px;
      display: flex;
      flex-direction: column;
      gap: 32px;
    }
    .drawer.open {
      transform: translateX(-300px); /* Glissement */
    }
    .drawer-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .btn-close-drawer {
      background: none;
      border: none;
      color: #64748b;
      font-size: 28px;
      cursor: pointer;
    }
    .btn-close-drawer:hover {
      color: white;
    }
    .drawer-links {
      display: flex;
      flex-direction: column;
      gap: 16px;
    }
    .drawer-links a {
      text-decoration: none;
      color: #94a3b8;
      font-size: 13px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1px;
      padding: 12px 16px;
      border-radius: 10px;
      transition: background 0.15s, color 0.15s;
    }
    .drawer-links a:hover {
      background: rgba(255,255,255,0.02);
      color: white;
    }
    .drawer-links a.active {
      color: #38bdf8;
      background: rgba(56, 189, 248, 0.05);
    }
    .admin-nav-link {
      color: #c084fc !important;
      text-shadow: 0 0 8px rgba(192, 132, 252, 0.4);
    }

    .btn-logout {
      background: none;
      border: none;
      color: #94a3b8;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      transition: color 0.15s ease;
    }
    .btn-logout:hover {
      color: white;
    }

    main {
      flex: 1;
      max-width: 1000px;
      width: 100%;
      margin: 0 auto;
      padding: 40px 24px;
      z-index: 10;
    }

    /* Fiche Profil de l'utilisateur connecté */
    .user-profile-header {
      background: rgba(15, 23, 42, 0.55);
      border: 1px solid rgba(255, 255, 255, 0.04);
      border-radius: 20px;
      padding: 24px;
      display: flex;
      align-items: center;
      gap: 20px;
      margin-bottom: 40px;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
    }
    .user-avatar {
      width: 64px;
      height: 64px;
      border-radius: 50%;
      border: 2px solid #1e293b;
      object-fit: cover;
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.3);
    }
    .user-info h3 {
      font-size: 18px;
      font-weight: 800;
      color: white;
    }
    .user-badges {
      display: flex;
      gap: 8px;
      margin-top: 6px;
    }
    .badge {
      font-size: 9px;
      font-weight: 800;
      padding: 4px 10px;
      border-radius: 6px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .badge-admin {
      color: #38bdf8;
      background: rgba(56, 189, 248, 0.1);
      border: 1px solid rgba(56, 189, 248, 0.2);
    }
    .badge-premium {
      color: #c084fc;
      background: rgba(192, 132, 252, 0.1);
      border: 1px solid rgba(192, 132, 252, 0.2);
    }
    .badge-free {
      color: #94a3b8;
      background: rgba(148, 163, 184, 0.05);
      border: 1px solid rgba(148, 163, 184, 0.15);
    }

    h2 {
      font-size: 24px;
      font-weight: 900;
      color: white;
      margin-bottom: 8px;
    }
    p.subtitle {
      font-size: 13px;
      color: #64748b;
      margin-bottom: 32px;
    }

    /* Grille des serveurs */
    .grid {
      display: grid;
      grid-template-cols: 1fr;
      gap: 24px;
    }
    @media (min-width: 600px) {
      .grid {
        grid-template-cols: repeat(2, 1fr);
      }
    }
    @media (min-width: 900px) {
      .grid {
        grid-template-cols: repeat(3, 1fr);
      }
    }

    .server-card {
      background: rgba(15, 23, 42, 0.45);
      border: 1px solid rgba(255, 255, 255, 0.04);
      border-radius: 20px;
      padding: 32px 24px;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      transition: box-shadow 0.3s ease, border-color 0.3s ease;
    }
    .server-card:hover {
      box-shadow: 0 0 25px rgba(6, 182, 212, 0.15);
      border-color: rgba(6, 182, 212, 0.3);
    }
    .server-icon {
      width: 76px;
      height: 76px;
      border-radius: 50%;
      border: 2px solid #1e293b;
      object-fit: cover;
      margin-bottom: 16px;
      box-shadow: 0 6px 15px rgba(0, 0, 0, 0.4);
    }
    .server-name {
      font-size: 16px;
      font-weight: 800;
      color: white;
      margin-bottom: 24px;
      width: 100%;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .btn-group {
      width: 100%;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .btn-manage {
      width: 100%;
      padding: 11px;
      background: linear-gradient(135deg, #06b6d4, #4f46e5);
      color: white;
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1px;
      text-decoration: none;
      border-radius: 10px;
      display: inline-block;
      transition: transform 0.1s;
      box-shadow: 0 4px 10px rgba(6, 182, 212, 0.15);
    }
    .btn-manage:active {
      transform: scale(0.98);
    }
    .btn-invite {
      width: 100%;
      padding: 11px;
      background: rgba(15, 23, 42, 0.3);
      border: 1px solid #1e293b;
      color: #94a3b8;
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1px;
      text-decoration: none;
      border-radius: 10px;
      display: inline-block;
      transition: border-color 0.15s, color 0.15s;
    }
    .btn-invite:hover {
      border-color: #334155;
      color: white;
    }

    footer {
      border-top: 1px solid #0f172a;
      padding: 24px;
      text-align: center;
      font-size: 12px;
      color: #475569;
    }
  </style>
</head>
<body>

  <div class="halo-top"></div>

  <!-- Barre de navigation -->
  <header>
    <a href="/" class="logo-area">
      <img src="/logo.png" id="logo-main-img" onerror="this.style.display='none'; document.getElementById('logo-fallback-box').style.display='flex';" class="logo-img" alt="OMNIX Logo">
      <div id="logo-fallback-box" style="display: none; width: 38px; height: 38px; border-radius: 10px; background: linear-gradient(135deg, #06b6d4, #7c3aed); align-items: center; justify-content: center; font-weight: 900; color: white; font-size: 18px; box-shadow: 0 4px 12px rgba(6, 182, 212, 0.2);">O</div>
      <span class="logo-text">OMNIX Panel</span>
    </a>
    
    <!-- Bouton d'ouverture du Menu Tiroir -->
    <button onclick="toggleDrawer(true)" class="btn-burger">
      <svg class="burger-icon" viewBox="0 0 24 24"><path d="M3 18h18v-2H3v2zm0-5h18v-2H3v2zm0-7v2h18V6H3z"/></svg>
    </button>
  </header>

  <!-- LIAISON DE LA BARRE LATÉRALE CENTRALISÉE -->
  <%- include('partials/sidebar') %>

  <!-- Contenu Principal -->
  <main>
    <section class="user-profile-header" id="user-header">
      <div style="width: 64px; height: 64px; border-radius: 50%; background: #1e293b;"></div>
      <div class="user-info">
        <h3 style="color: #475569;">En attente d'authentification...</h3>
      </div>
    </section>

    <h2>Sélectionnez votre serveur</h2>
    <p class="subtitle">Seuls les serveurs sur lesquels vous possédez les droits d'administration sont listés.</p>

    <div id="guilds-grid" class="grid">
      <div class="col-span-full" id="loading-label" style="text-align: center; color: #64748b; padding: 48px 0;">
        Vérification sécurisée et chargement de vos serveurs...
      </div>
    </div>
  </main>

  <footer>
    <p>&copy; 2026 OMNIX. Tous droits réservés.</p>
  </footer>

  <script>
    const clientId = "<%= clientId %>";

    // Fonction d'initialisation
    function startDashboard() {
      const urlParams = new URLSearchParams(window.location.search);
      const tokenFromUrl = urlParams.get('token');
      
      if (tokenFromUrl) {
        setToken(tokenFromUrl);
        window.history.replaceState({}, document.title, window.location.pathname);
      }

      const jwtToken = getToken();
      if (!jwtToken) {
        setTimeout(() => { window.location.href = '/'; }, 1500);
        return;
      }

      renderUserProfile(jwtToken);
      loadGuilds(jwtToken);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', startDashboard);
    } else {
      startDashboard();
    }

    function renderUserProfile(jwtToken) {
      const payload = parseJwt(jwtToken);
      if (!payload) {
        logout();
        return;
      }

      const userHeader = document.getElementById('user-header');
      const avatarUrl = payload.avatar 
        ? `https://cdn.discordapp.com/avatars/${payload.discordId}/${payload.avatar}.png` 
        : 'https://cdn.discordapp.com/embed/avatars/0.png';

      let badgesHtml = '';
      if (payload.isAdmin) {
        badgesHtml += `<span class="badge badge-admin">Admin</span>`;
      }
      if (payload.isPremium) {
        badgesHtml += `<span class="badge badge-premium">Premium</span>`;
      }
      if (!payload.isAdmin && !payload.isPremium) {
        badgesHtml += `<span class="badge badge-free">Free User</span>`;
      }

      userHeader.innerHTML = `
        <img src="${avatarUrl}" class="user-avatar" alt="Avatar">
        <div class="user-info">
          <h3>${payload.username}</h3>
          <div class="user-badges">
            ${badgesHtml}
          </div>
        </div>
      `;
    }

    async function loadGuilds(jwtToken) {
      try {
        const response = await fetch('/api/guilds', {
          headers: { 'Authorization': `Bearer ${jwtToken}` }
        });

        if (!response.ok) {
          throw new Error();
        }

        const guilds = await response.json();
        const grid = document.getElementById('guilds-grid');
        grid.innerHTML = '';

        if (guilds.length === 0) {
          grid.innerHTML = `<div style="text-align: center; color: #94a3b8; grid-column: 1/-1; padding: 48px 0;">Aucun serveur administrable trouvé.</div>`;
          return;
        }

        guilds.forEach(guild => {
          const card = document.createElement('div');
          card.className = "server-card";

          const avatarUrl = guild.icon 
            ? `https://cdn.discordapp.com/icons/${guild.id}/${guild.icon}.png` 
            : 'https://cdn.discordapp.com/embed/avatars/0.png';

          const inviteUrl = `https://discord.com/api/oauth2/authorize?client_id=${clientId}&permissions=8&scope=bot%20applications.commands&guild_id=${guild.id}`;

          card.innerHTML = `
            <img src="${avatarUrl}" class="server-icon" alt="${guild.name}">
            <h3 class="server-name">${guild.name}</h3>
            <div class="btn-group">
              <a href="/dashboard/${guild.id}" class="btn-manage">Gérer</a>
              <a href="${inviteUrl}" target="_blank" class="btn-invite">Inviter le bot</a>
            </div>
          `;
          grid.appendChild(card);
        });

      } catch (error) {
        document.getElementById('loading-label').innerText = "Session expirée. Redirection...";
        setTimeout(() => logout(), 1500);
      }
    }
  </script>
</body>
</html>