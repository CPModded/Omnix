<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>OMNIX - Console</title>
  <style>
    /* Styles CSS natifs */
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      background-color: #030712;
      color: #f1f5f9;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      position: relative;
      overflow-x: hidden;
      line-height: 1.5;
    }
    .halo-bottom { position: absolute; bottom: -150px; left: -150px; width: 500px; height: 500px; background: rgba(139, 92, 246, 0.05); filter: blur(100px); border-radius: 50%; pointer-events: none; }
    header {
      border-bottom: 1px solid #1e293b;
      background: rgba(15, 23, 42, 0.7);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      padding: 16px 24px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      position: sticky;
      top: 0;
      z-index: 50;
    }
    .logo-area { display: flex; align-items: center; gap: 12px; text-decoration: none; }
    .logo-img { width: 38px; height: 38px; border-radius: 10px; object-fit: cover; }
    .back-link { text-decoration: none; color: #94a3b8; font-size: 13px; font-weight: 600; }
    .logo-text { font-weight: 800; letter-spacing: 1px; background: linear-gradient(to right, #60a5fa, #22d3ee, #a78bfa); -webkit-background-clip: text; -webkit-text-fill-color: transparent; font-size: 16px; }

    .btn-burger { background: none; border: none; color: #94a3b8; cursor: pointer; display: flex; align-items: center; }
    .burger-icon { width: 24px; height: 24px; fill: currentColor; }
    .drawer {
      position: fixed;
      top: 0;
      right: -300px;
      width: 280px;
      height: 100vh;
      background: rgba(15, 23, 42, 0.85);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      border-left: 1px solid rgba(255, 255, 255, 0.04);
      z-index: 1000;
      transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      padding: 32px 24px;
      display: flex;
      flex-direction: column;
      gap: 32px;
    }
    .drawer.open { transform: translateX(-300px); }
    .btn-close-drawer { background: none; border: none; color: #64748b; font-size: 28px; cursor: pointer; }
    .drawer-links { display: flex; flex-direction: column; gap: 16px; }
    .drawer-links a { text-decoration: none; color: #94a3b8; font-size: 13px; font-weight: 700; text-transform: uppercase; padding: 12px 16px; border-radius: 10px; transition: background 0.15s, color 0.15s; }
    .drawer-links a:hover { background: rgba(255,255,255,0.02); color: white; }
    .drawer-links a.active { color: #38bdf8; background: rgba(56, 189, 248, 0.05); }

    .container { flex: 1; max-width: 1100px; width: 100%; margin: 0 auto; padding: 40px 24px; display: flex; flex-direction: column; gap: 32px; z-index: 10; }
    @media (min-width: 768px) { .container { flex-direction: row; } }

    aside { display: flex; flex-direction: row; gap: 8px; overflow-x: auto; padding-bottom: 16px; }
    @media (min-width: 768px) { aside { width: 250px; flex-direction: column; overflow-x: visible; padding-bottom: 0; } }
    .tab-btn { width: 100%; text-align: left; padding: 14px 20px; border-radius: 12px; font-size: 11px; font-weight: 700; text-transform: uppercase; background: none; border: none; color: #94a3b8; cursor: pointer; }
    .tab-btn:hover { background: rgba(15, 23, 42, 0.4); color: white; }
    .tab-btn.active { background: #4f46e5; color: white; box-shadow: 0 4px 12px rgba(79, 70, 229, 0.2); }

    .config-panel { flex: 1; background: rgba(15, 23, 42, 0.45); border: 1px solid rgba(255, 255, 255, 0.04); border-radius: 24px; padding: 32px; box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); position: relative; }
    .hidden { display: none !important; }

    .license-card { padding: 20px; background: rgba(3, 7, 18, 0.6); border: 1px solid rgba(255, 255, 255, 0.03); border-radius: 16px; display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; }
    .license-title { font-weight: 800; font-size: 16px; color: white; }
    .license-sub { font-size: 11px; color: #475569; margin-top: 4px; }
    .badge-free { font-size: 10px; font-weight: 700; color: #94a3b8; background: rgba(15, 23, 42, 0.6); border: 1px solid #334155; padding: 6px 14px; border-radius: 20px; }
    .badge-premium { font-size: 10px; font-weight: 700; color: #34d399; background: rgba(6, 78, 59, 0.2); border: 1px solid rgba(52, 211, 153, 0.3); padding: 6px 14px; border-radius: 20px; }

    .switch-row { display: flex; justify-content: space-between; align-items: center; padding: 20px; background: rgba(3, 7, 18, 0.4); border: 1px solid rgba(255, 255, 255, 0.02); border-radius: 16px; margin-bottom: 24px; }
    .switch-title { font-weight: 700; font-size: 14px; color: white; }
    .switch-sub { font-size: 11px; color: #64748b; margin-top: 4px; }

    .ios-toggle { width: 44px; height: 24px; background: #1e293b; border-radius: 20px; appearance: none; -webkit-appearance: none; cursor: pointer; position: relative; outline: none; transition: background 0.2s ease; }
    .ios-toggle:checked { background: #4f46e5; }
    .ios-toggle::after { content: ''; position: absolute; width: 20px; height: 20px; background: white; border-radius: 50%; top: 2px; left: 2px; transition: transform 0.2s ease; }
    .ios-toggle:checked::after { transform: translateX(20px); }

    .form-group { margin-bottom: 24px; }
    label { display: block; font-size: 10px; font-weight: 700; color: #94a3b8; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px; }
    input[type="text"], input[type="number"], textarea, select { width: 100%; background-color: #030712; border: 1px solid #1e293b; border-radius: 12px; padding: 12px 16px; font-size: 14px; color: white; font-family: inherit; }
    input:focus, textarea:focus, select:focus { border-color: #4f46e5; outline: none; }
    .form-grid { display: grid; grid-template-cols: 1fr; gap: 16px; }
    @media (min-width: 600px) { .form-grid { grid-template-cols: repeat(2, 1fr); } }

    .save-btn-container { margin-top: 40px; border-top: 1px solid #1e293b; padding-top: 24px; display: flex; justify-content: flex-end; }
    .btn-save { padding: 14px 24px; background: linear-gradient(135deg, #06b6d4, #4f46e5); color: white; font-size: 12px; font-weight: 700; text-transform: uppercase; border: none; border-radius: 12px; cursor: pointer; box-shadow: 0 4px 12px rgba(79, 70, 229, 0.2); }
    .btn-save:active { transform: scale(0.98); }
    .toast { position: absolute; bottom: 24px; right: 24px; padding: 14px 20px; background-color: #059669; color: white; font-weight: 700; font-size: 13px; border-radius: 12px; box-shadow: 0 10px 20px rgba(0, 0, 0, 0.3); z-index: 100; }

    /* SIMULATEUR D'EMBED DISCORD INTERACTIF (Visual Preview) */
    .discord-preview-container {
      margin-top: 32px;
      padding: 24px;
      background-color: #313338; /* Discord Gray 300 */
      border-radius: 16px;
      border: 1px solid #1e1f22;
      text-align: left;
    }
    .discord-header { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; }
    .discord-bot-avatar { width: 40px; height: 40px; border-radius: 50%; background: #5865f2; display: flex; align-items: center; justify-content: center; font-weight: bold; color: white; font-size: 14px; }
    .discord-bot-name { font-weight: 700; font-size: 14px; color: #f2f3f5; }
    .discord-bot-badge { font-size: 9px; font-weight: 800; background-color: #5865f2; color: white; padding: 2px 6px; border-radius: 4px; text-transform: uppercase; margin-left: 6px; }
    .discord-embed-card {
      border-left: 4px solid #06b6d4; /* Couleur dynamique modifiable */
      background-color: #2b2d31; /* Discord Gray 400 */
      padding: 16px;
      border-radius: 4px;
      max-width: 520px;
    }
    .discord-embed-title { font-weight: 700; font-size: 15px; color: #ffffff; margin-bottom: 8px; }
    .discord-embed-desc { font-size: 13px; color: #dbdee1; line-height: 1.5; white-space: pre-wrap; }
  </style>
</head>
<body>

  <div class="halo-bottom"></div>

  <header>
    <a href="/dashboard" class="logo-area">
      <img src="/logo.png" id="logo-main-img" onerror="this.style.display='none'; document.getElementById('logo-fallback-box').style.display='flex';" class="logo-img" alt="OMNIX Logo">
      <div id="logo-fallback-box" style="display: none; width: 38px; height: 38px; border-radius: 10px; background: linear-gradient(135deg, #06b6d4, #7c3aed); align-items: center; justify-content: center; font-weight: 900; color: white; font-size: 18px; box-shadow: 0 4px 12px rgba(6, 182, 212, 0.2);">O</div>
      <span class="logo-text">OMNIX Config</span>
    </a>
    <button onclick="toggleDrawer(true)" class="btn-burger">
      <svg class="burger-icon" viewBox="0 0 24 24"><path d="M3 18h18v-2H3v2zm0-5h18v-2H3v2zm0-7v2h18V6H3z"/></svg>
    </button>
  </header>

  <div id="side-drawer" class="drawer">
    <div class="drawer-header">
      <span class="logo-text">Menu</span>
      <button onclick="toggleDrawer(false)" class="btn-close-drawer">&times;</button>
    </div>
    <div class="drawer-links" id="drawer-nav">
      <a href="/">Accueil</a>
      <a href="/dashboard">Dashboard</a>
      <a href="/founder">Founder</a>
    </div>
  </div>

  <div class="container">
    <aside>
      <button onclick="switchTab('tab-overview')" id="btn-tab-general" class="tab-btn active">Vue d'ensemble</button>
      <button onclick="switchTab('tab-welcome')" id="btn-tab-welcome" class="tab-btn">Accueil & Départ</button>
      <button onclick="switchTab('tab-moderation')" id="btn-tab-moderation" class="tab-btn">Modération & AutoMod</button>
      <button onclick="switchTab('tab-tickets')" id="btn-tab-tickets" class="tab-btn">Support & Tickets</button>
      <button onclick="switchTab('tab-economy')" id="btn-tab-economy" class="tab-btn">Économie & Niveaux</button>
      <button onclick="switchTab('tab-ai')" id="btn-tab-ai" class="tab-btn">IA & Intelligence</button>
      <button onclick="switchTab('tab-backups')" id="btn-tab-backups" class="tab-btn">Sauvegardes (Premium)</button>
    </aside>

    <main class="config-panel">
      <!-- Onglet 1 : Vue d'ensemble -->
      <section id="tab-overview" class="tab-content">
        <h3 style="font-size: 18px; font-weight: 800; color: white; margin-bottom: 24px;">Fiche d'identité</h3>
        <div class="license-card">
          <div>
            <p class="license-title" id="license-label">Vérification de la licence...</p>
            <p class="license-sub" id="license-expiration"></p>
          </div>
          <span id="license-badge" class="badge-free">FREE</span>
        </div>

        <h4 style="font-size: 13px; font-weight: 800; color: white; margin-top: 32px; margin-bottom: 16px; text-transform: uppercase; letter-spacing: 0.8px;">Activation des Commandes</h4>
        <div class="switch-row"><div class="switch-title">Commande : /ai (Premium)</div><input type="checkbox" id="ai-enabled-toggle" class="ios-toggle"></div>
        <div class="switch-row"><div class="switch-title">Commande : /backup (Premium)</div><input type="checkbox" id="backups-enabled-toggle" class="ios-toggle"></div>
        <div class="switch-row"><div class="switch-title">Commande : /economy</div><input type="checkbox" id="economy-enabled-toggle" class="ios-toggle"></div>
        <div class="switch-row"><div class="switch-title">Commande : /moderation</div><input type="checkbox" id="moderation-enabled-toggle" class="ios-toggle"></div>
        <div class="switch-row"><div class="switch-title">Commande : /ticket</div><input type="checkbox" id="tickets-enabled-toggle" class="ios-toggle"></div>
        <div class="switch-row"><div class="switch-title">Commande : /ping</div><input type="checkbox" id="ping-enabled-toggle" class="ios-toggle"></div>
      </section>

      <!-- Onglet 2 : Accueil & Départ -->
      <section id="tab-welcome" class="tab-content hidden">
        <h3 style="font-size: 18px; font-weight: 800; color: white; margin-bottom: 24px;">Accueil & Départ</h3>
        <div class="switch-row"><div><p class="switch-title">Activer le module d'accueil (Welcome)</p></div><input type="checkbox" id="welcome-enabled" class="ios-toggle"></div>
        <div class="form-group">
          <label>Salon de réception des messages de bienvenue</label>
          <select id="welcome-channel"><option value="">Sélectionnez un salon...</option></select>
        </div>
        <div class="form-group">
          <label>Message d'accueil personnalisé</label>
          <textarea id="welcome-message" rows="3" oninput="updateEmbedPreview()"></textarea>
        </div>

        <!-- SIMULATEUR DISCORD INTERACTIF EN TEMPS RÉEL (WYSIWYG) -->
        <div class="discord-preview-container">
          <div class="discord-header">
            <div class="discord-bot-avatar">O</div>
            <div class="discord-bot-name">OMNIX<span class="discord-bot-badge">Bot</span></div>
          </div>
          <div class="discord-embed-card">
            <div class="discord-embed-title">Bienvenue sur le serveur !</div>
            <div class="discord-embed-desc" id="discord-preview-text">Bienvenue [Utilisateur] sur le serveur !</div>
          </div>
        </div>

        <div class="switch-row" style="margin-top: 32px;"><div><p class="switch-title">Activer le module de départ (Goodbye)</p></div><input type="checkbox" id="goodbye-enabled" class="ios-toggle"></div>
        <div class="form-group">
          <label>Salon de réception des messages de départ</label>
          <select id="goodbye-channel"><option value="">Sélectionnez un salon...</option></select>
        </div>
        <div class="form-group">
          <label>Message de départ personnalisé</label>
          <textarea id="goodbye-message" rows="3"></textarea>
        </div>
      </section>

      <!-- Onglet 3 : Modération & AutoMod -->
      <section id="tab-moderation" class="tab-content hidden">
        <h3 style="font-size: 18px; font-weight: 800; color: white; margin-bottom: 24px;">Modération & Sécurité</h3>
        <div class="switch-row"><div><p class="switch-title">Activer le module de modération</p></div><input type="checkbox" id="moderation-enabled" class="ios-toggle"></div>
        <div class="form-group">
          <label>Salon de logs d'audit</label>
          <select id="moderation-log"><option value="">Sélectionnez un salon...</option></select>
        </div>

        <div class="switch-row"><div><p class="switch-title">Activer le filtre de censure AutoMod</p></div><input type="checkbox" id="automod-enabled" class="ios-toggle"></div>
        <div class="form-group" style="margin-bottom: 32px;">
          <label>Mots censurés (séparés par une virgule)</label>
          <input type="text" id="automod-words" placeholder="Ex: insulte1, insulte2, pub">
        </div>

        <h4 style="font-size: 13px; font-weight: 800; color: white; margin-bottom: 16px; border-top: 1px solid #1e293b; padding-top: 24px;">Honeypot (Piège Anti-Bots)</h4>
        <div class="switch-row"><div><p class="switch-title">Activer le système Honeypot (Premium)</p></div><input type="checkbox" id="honeypot-enabled" class="ios-toggle"></div>
        <div class="form-group">
          <label>Salon piégé d'exclusion directe</label>
          <select id="honeypot-channel"><option value="">Sélectionnez un salon...</option></select>
        </div>
      </section>

      <!-- Onglet 4 : Support & Tickets -->
      <section id="tab-tickets" class="tab-content hidden">
        <h3 style="font-size: 18px; font-weight: 800; color: white; margin-bottom: 24px;">Gestion des Tickets</h3>
        <div class="switch-row"><div><p class="switch-title">Activer le module de tickets</p></div><input type="checkbox" id="tickets-enabled" class="ios-toggle"></div>
        <div class="form-group">
          <label>Catégorie d'ouverture des salons de support</label>
          <select id="tickets-category"><option value="">Sélectionnez une catégorie...</option></select>
        </div>
      </section>

      <!-- Onglet 5 : Économie & Niveaux -->
      <section id="tab-economy" class="tab-content hidden">
        <h3 style="font-size: 18px; font-weight: 800; color: white; margin-bottom: 24px;">Économie & Niveaux d'XP</h3>
        <div class="switch-row"><div><p class="switch-title">Activer l'économie virtuelle</p></div><input type="checkbox" id="economy-enabled" class="ios-toggle"></div>
        <div class="form-grid">
          <div class="form-group"><label>Symbole de la monnaie</label><input type="text" id="economy-symbol"></div>
          <div class="form-group"><label>Délai d'attente (Cooldown en minutes)</label><input type="number" id="economy-cooldown"></div>
        </div>

        <div class="switch-row" style="margin-top: 24px;"><div><p class="switch-title">Activer le système de Niveaux & XP</p></div><input type="checkbox" id="levels-enabled" class="ios-toggle"></div>
        <div class="form-group"><label>Points d'XP par message</label><input type="number" id="levels-xp"></div>
      </section>

      <!-- Onglet 6 : Intelligence Artificielle -->
      <section id="tab-ai" class="tab-content hidden">
        <h3 style="font-size: 18px; font-weight: 800; color: white; margin-bottom: 24px;">Intelligence Artificielle</h3>
        <div class="switch-row"><div><p class="switch-title">Activer l'assistant virtuel (IA)</p></div><input type="checkbox" id="ai-enabled" class="ios-toggle"></div>
        <div class="form-group"><label>Prompt Système (Instructions)</label><textarea id="ai-prompt" rows="5"></textarea></div>
      </section>

      <!-- Onglet 7 : Sauvegardes (Premium) -->
      <section id="tab-backups" class="tab-content hidden">
        <h3 style="font-size: 18px; font-weight: 800; color: white; margin-bottom: 24px;">Sauvegardes & Restauration</h3>
        <div class="switch-row"><div><p class="switch-title">Activer l'archivage automatique</p></div><input type="checkbox" id="backups-enabled" class="ios-toggle"></div>
        <div style="padding: 24px; background: rgba(3, 7, 18, 0.4); border: 1px solid rgba(255, 255, 255, 0.02); border-radius: 16px;">
          <h4 style="font-size: 14px; font-weight: 700; color: white; margin-bottom: 8px;">Gestion des instantanés</h4>
          <p style="font-size: 11px; color: #64748b; line-height: 1.5; margin-bottom: 16px;">Créez un point de restauration complet de vos configurations actuelles directement sur votre base privée.</p>
          <button onclick="triggerBackup()" style="padding: 10px 16px; background-color: #4f46e5; border: none; border-radius: 8px; color: white; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; cursor: pointer;">Créer un instantané manuel</button>
        </div>
      </section>

      <!-- Bouton d'enregistrement permanent -->
      <div class="save-btn-container"><button onclick="saveConfig()" class="btn-save">Enregistrer les paramètres</button></div>
      <div id="toast" class="toast hidden">Paramètres enregistrés avec succès !</div>
    </main>
  </div>

  <footer><p>&copy; 2026 OMNIX. Tous droits réservés.</p></footer>

  <script>
    const guildId = "<%= guildId %>";
    const jwtToken = localStorage.getItem('jwt_token');

    if (!jwtToken) { window.location.href = '/'; }

    function toggleDrawer(open) {
      const drawer = document.getElementById('side-drawer');
      if (open) { drawer.classList.add('open'); } else { drawer.classList.remove('open'); }
    }

    function parseJwt(token) {
      if (!token || token === 'null' || token === 'undefined' || !token.includes('.')) return null;
      try {
        const base64Url = token.split('.')[1];
        const base64 = base64Url.replace(/-/g, '+').replace(/_/g, '/');
        const pad = base64.length % 4;
        const paddedBase64 = pad ? base64 + '='.repeat(4 - pad) : base64;
        const rawBinary = window.atob(paddedBase64);
        const bytes = new Uint8Array(rawBinary.length);
        for (let i = 0; i < rawBinary.length; i++) { bytes[i] = rawBinary.charCodeAt(i); }
        const decoder = new TextDecoder('utf-8');
        return JSON.parse(decoder.decode(bytes));
      } catch (e) { return null; }
    }

    function renderDrawerMenu() {
      const payload = parseJwt(jwtToken);
      if (payload && payload.isAdmin) {
        const nav = document.getElementById('drawer-nav');
        if (nav && !document.getElementById('nav-admin-link')) {
          const adminLink = document.createElement('a');
          adminLink.href = '/admin';
          adminLink.id = 'nav-admin-link';
          adminLink.className = 'admin-nav-link';
          adminLink.innerText = 'Staff Panel';
          nav.appendChild(adminLink);
        }
      }
    }

    function switchTab(tabId) {
      document.querySelectorAll('.tab-content').forEach(el => el.classList.add('hidden'));
      document.getElementById(tabId).classList.remove('hidden');
      document.querySelectorAll('aside button').forEach(el => { el.className = "tab-btn"; });
      const activeBtn = document.getElementById('btn-' + tabId);
      if (activeBtn) activeBtn.className = "tab-btn active";
    }

    function updateEmbedPreview() {
      const text = document.getElementById('welcome-message').value;
      const preview = document.getElementById('discord-preview-text');
      // Remplacement visuel de la variable {user} dans l'éditeur de prévisualisation
      preview.innerText = text.replace(/{user}/g, "@le.m135") || "Bienvenue sur le serveur !";
    }

    function setupCheckboxSync() {
      const pairs = [
        { main: 'ai-enabled', toggle: 'ai-enabled-toggle' },
        { main: 'backups-enabled', toggle: 'backups-enabled-toggle' },
        { main: 'economy-enabled', toggle: 'economy-enabled-toggle' },
        { main: 'moderation-enabled', toggle: 'moderation-enabled-toggle' },
        { main: 'tickets-enabled', toggle: 'tickets-enabled-toggle' }
      ];
      pairs.forEach(pair => {
        const mainEl = document.getElementById(pair.main);
        const toggleEl = document.getElementById(pair.toggle);
        if (mainEl && toggleEl) {
          mainEl.addEventListener('change', (e) => { toggleEl.checked = e.target.checked; });
          toggleEl.addEventListener('change', (e) => { mainEl.checked = e.target.checked; });
        }
      });
    }

    // Récupère dynamiquement les salons et catégories du serveur Discord
    async function loadDiscordChannels() {
      try {
        const response = await fetch(`/api/guilds/${guildId}/channels`, {
          headers: { 'Authorization': `Bearer ${jwtToken}` }
        });
        if (!response.ok) throw new Error();
        const channels = await response.json();

        const welcomeSelect = document.getElementById('welcome-channel');
        const goodbyeSelect = document.getElementById('goodbye-channel');
        const moderationLogSelect = document.getElementById('moderation-log');
        const ticketsCategorySelect = document.getElementById('tickets-category');
        const honeypotSelect = document.getElementById('honeypot-channel');

        channels.forEach(ch => {
          const opt = document.createElement('option');
          opt.value = ch.id;
          opt.innerText = ch.name;

          if (ch.type === 'text') {
            welcomeSelect.appendChild(opt.cloneNode(true));
            goodbyeSelect.appendChild(opt.cloneNode(true));
            moderationLogSelect.appendChild(opt.cloneNode(true));
            honeypotSelect.appendChild(opt.cloneNode(true));
          } else if (ch.type === 'category') {
            ticketsCategorySelect.appendChild(opt);
          }
        });
      } catch (e) {
        console.error("Impossible de récupérer les salons Discord.");
      }
    }

    async function loadConfig() {
      try {
        // Chargement des salons Discord d'abord
        await loadDiscordChannels();

        const response = await fetch(`/api/guilds/${guildId}/config`, {
          headers: { 'Authorization': `Bearer ${jwtToken}` }
        });

        if (!response.ok) {
          const errData = await response.json().catch(() => ({}));
          throw new Error(errData.details || errData.error || `Erreur HTTP ${response.status}`);
        }

        const config = await response.json();

        const payload = parseJwt(jwtToken);
        const isUserPremium = payload && (payload.isPremium || payload.isAdmin);
        const isGuildPremium = config.premium?.isPremium;

        const licenseLabel = document.getElementById('license-label');
        const badge = document.getElementById('license-badge');
        
        if (isGuildPremium || isUserPremium) {
          licenseLabel.innerText = isGuildPremium ? `Premium Activé (${config.premium.tier.toUpperCase()})` : "Premium Actif (Licence Utilisateur Personnelle)";
          badge.className = "badge-premium";
          badge.innerText = "PREMIUM";
        } else {
          licenseLabel.innerText = "Version d'évaluation standard";
          badge.className = "badge-free";
          badge.innerText = "FREE";
        }

        document.getElementById('welcome-enabled').checked = config.modules?.welcome?.enabled || false;
        document.getElementById('welcome-message').value = config.modules?.welcome?.message || "Bienvenue {user} !";
        document.getElementById('welcome-channel').value = config.modules?.welcome?.channelId || "";

        document.getElementById('goodbye-enabled').checked = config.modules?.goodbye?.enabled || false;
        document.getElementById('goodbye-message').value = config.modules?.goodbye?.message || "Au revoir {user}...";
        document.getElementById('goodbye-channel').value = config.modules?.goodbye?.channelId || "";

        document.getElementById('moderation-enabled').checked = config.modules?.moderation?.enabled || false;
        document.getElementById('moderation-log').value = config.modules?.moderation?.logChannelId || "";
        
        document.getElementById('automod-enabled').checked = config.modules?.autoMod?.enabled || false;
        document.getElementById('automod-words').value = (config.modules?.autoMod?.blacklistedWords || []).join(', ');

        document.getElementById('tickets-enabled').checked = config.modules?.tickets?.enabled || false;
        document.getElementById('tickets-category').value = config.modules?.tickets?.categoryId || "";

        document.getElementById('economy-enabled').checked = config.modules?.economy?.enabled || false;
        document.getElementById('economy-symbol').value = config.modules?.economy?.currencySymbol || "$";
        document.getElementById('economy-cooldown').value = config.modules?.economy?.workCooldownMinutes || 60;
        
        document.getElementById('levels-enabled').checked = config.modules?.levels?.enabled || false;
        document.getElementById('levels-xp').value = config.modules?.levels?.xpPerMessage || 15;

        document.getElementById('ai-enabled').checked = config.modules?.ai?.enabled || false;
        document.getElementById('ai-prompt').value = config.modules?.ai?.systemPrompt || "Tu es un assistant utile.";

        document.getElementById('backups-enabled').checked = config.modules?.backups?.enabled || false;
        document.getElementById('honeypot-enabled').checked = config.modules?.honeypot?.enabled || false;
        document.getElementById('honeypot-channel').value = config.modules?.honeypot?.channelId || "";

        document.getElementById('ai-enabled-toggle').checked = config.modules?.ai?.enabled || false;
        document.getElementById('backups-enabled-toggle').checked = config.modules?.backups?.enabled || false;
        document.getElementById('economy-enabled-toggle').checked = config.modules?.economy?.enabled || false;
        document.getElementById('moderation-enabled-toggle').checked = config.modules?.moderation?.enabled || false;
        document.getElementById('tickets-enabled-toggle').checked = config.modules?.tickets?.enabled || false;
        document.getElementById('ping-enabled-toggle').checked = config.modules?.ping?.enabled || true;

        updateEmbedPreview();

      } catch (error) {
        alert("Impossible de charger les configurations :\n\n" + error.message);
        window.location.href = '/dashboard';
      }
    }

    async function saveConfig() {
      const payload = {
        modules: {
          welcome: {
            enabled: document.getElementById('welcome-enabled').checked,
            message: document.getElementById('welcome-message').value,
            channelId: document.getElementById('welcome-channel').value || null,
            useEmbed: false
          },
          goodbye: {
            enabled: document.getElementById('goodbye-enabled').checked,
            message: document.getElementById('goodbye-message').value,
            channelId: document.getElementById('goodbye-channel').value || null,
            useEmbed: false
          },
          moderation: {
            enabled: document.getElementById('moderation-enabled').checked || document.getElementById('moderation-enabled-toggle').checked,
            logChannelId: document.getElementById('moderation-log').value || null
          },
          autoMod: {
            enabled: document.getElementById('automod-enabled').checked,
            blacklistedWords: document.getElementById('automod-words').value.split(',').map(w => w.trim()).filter(Boolean)
          },
          tickets: {
            enabled: document.getElementById('tickets-enabled').checked || document.getElementById('tickets-enabled-toggle').checked,
            categoryId: document.getElementById('tickets-category').value || null,
            counter: 0
          },
          economy: {
            enabled: document.getElementById('economy-enabled').checked || document.getElementById('economy-enabled-toggle').checked,
            currencySymbol: document.getElementById('economy-symbol').value,
            workCooldownMinutes: parseInt(document.getElementById('economy-cooldown').value, 10) || 60
          },
          levels: {
            enabled: document.getElementById('levels-enabled').checked,
            xpPerMessage: parseInt(document.getElementById('levels-xp').value, 10) || 15,
            rewardRoles: []
          },
          ai: {
            enabled: document.getElementById('ai-enabled').checked || document.getElementById('ai-enabled-toggle').checked,
            systemPrompt: document.getElementById('ai-prompt').value,
            contextLimit: 10
          },
          backups: {
            enabled: document.getElementById('backups-enabled').checked || document.getElementById('backups-enabled-toggle').checked
          },
          ping: {
            enabled: document.getElementById('ping-enabled-toggle').checked
          },
          honeypot: {
            enabled: document.getElementById('honeypot-enabled').checked,
            channelId: document.getElementById('honeypot-channel').value || null
          }
        }
      };

      try {
        const response = await fetch(`/api/guilds/${guildId}/config`, {
          method: 'PUT',
          headers: {
            'Authorization': `Bearer ${jwtToken}`,
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(payload)
        });

        if (!response.ok) {
          const errData = await response.json();
          throw new Error(errData.message || errData.error);
        }

        const toast = document.getElementById('toast');
        toast.classList.remove('hidden');
        setTimeout(() => toast.classList.add('hidden'), 3000);

        loadConfig();

      } catch (error) {
        alert("Une erreur est survenue lors de l'enregistrement : " + error.message);
      }
    }

    async function triggerBackup() {
      try {
        const response = await fetch(`/api/guilds/${guildId}/backups`, {
          method: 'POST',
          headers: { 'Authorization': `Bearer ${jwtToken}` }
        });

        if (!response.ok) {
          const errData = await response.json().catch(() => ({}));
          throw new Error(errData.message || errData.error || `Erreur HTTP ${response.status}`);
        }

        alert("✅ Instantané de sauvegarde créé avec succès !");
      } catch (error) {
        alert("❌ Échec de la création de la sauvegarde : " + error.message);
      }
    }

    renderDrawerMenu();
    setupCheckboxSync();
    loadConfig();
  </script>
</body>
</html>