<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>OMNIX - Abonnements</title>
  <style>
    /* Styles CSS natifs */
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      background-color: #030712;
      color: #f1f5f9;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      position: relative;
      overflow-x: hidden;
      line-height: 1.5;
    }
    .halo {
      position: absolute;
      top: -150px;
      left: -150px;
      width: 500px;
      height: 500px;
      background: rgba(124, 58, 237, 0.05);
      filter: blur(100px);
      border-radius: 50%;
      pointer-events: none;
    }
    header {
      border-bottom: 1px solid #1e293b;
      background: rgba(15, 23, 42, 0.7);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      padding: 16px 24px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      position: sticky;
      top: 0;
      z-index: 50;
    }
    .logo-area { display: flex; align-items: center; gap: 12px; text-decoration: none; }
    .logo-img { width: 38px; height: 38px; border-radius: 10px; object-fit: cover; }
    .logo-text {
      font-weight: 800;
      letter-spacing: 1px;
      background: linear-gradient(to right, #60a5fa, #22d3ee, #a78bfa);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      font-size: 18px;
    }
    
    .btn-burger { background: none; border: none; color: #94a3b8; cursor: pointer; }
    .burger-icon { width: 24px; height: 24px; fill: currentColor; }
    .drawer {
      position: fixed;
      top: 0;
      right: -300px;
      width: 280px;
      height: 100vh;
      background: rgba(15, 23, 42, 0.85);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      border-left: 1px solid rgba(255, 255, 255, 0.04);
      z-index: 1000;
      transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      padding: 32px 24px;
      display: flex;
      flex-direction: column;
      gap: 32px;
    }
    .drawer.open { transform: translateX(-300px); }
    .btn-close-drawer { background: none; border: none; color: #64748b; font-size: 28px; cursor: pointer; }
    .drawer-links { display: flex; flex-direction: column; gap: 16px; }
    .drawer-links a {
      text-decoration: none;
      color: #94a3b8;
      font-size: 13px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1px;
      padding: 12px 16px;
      border-radius: 10px;
      transition: background 0.15s, color 0.15s;
    }
    .drawer-links a:hover { background: rgba(255,255,255,0.02); color: white; }
    .drawer-links a.active { color: #38bdf8; background: rgba(56, 189, 248, 0.05); }

    main {
      flex: 1;
      max-width: 1000px;
      width: 100%;
      margin: 0 auto;
      padding: 60px 24px;
      text-align: center;
      z-index: 10;
    }
    h2 { font-size: 32px; font-weight: 900; color: white; margin-bottom: 8px; }
    p.subtitle { font-size: 14px; color: #64748b; margin-bottom: 48px; }

    /* Grille de Prix à 4 colonnes */
    .pricing-grid {
      display: grid;
      grid-template-cols: 1fr;
      gap: 24px;
    }
    @media (min-width: 600px) {
      .pricing-grid { grid-template-cols: repeat(2, 1fr); }
    }
    @media (min-width: 900px) {
      .pricing-grid { grid-template-cols: repeat(4, 1fr); }
    }
    .price-card {
      background: rgba(15, 23, 42, 0.45);
      border: 1px solid rgba(255, 255, 255, 0.04);
      border-radius: 20px;
      padding: 32px 20px;
      text-align: center;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      box-shadow: 0 10px 30px rgba(0,0,0,0.3);
      transition: border-color 0.3s ease, box-shadow 0.3s ease;
    }
    .price-card:hover {
      border-color: rgba(6, 182, 212, 0.25);
      box-shadow: 0 0 20px rgba(6, 182, 212, 0.1);
    }
    .price-card.featured {
      border-color: rgba(139, 92, 246, 0.3);
      box-shadow: 0 0 25px rgba(139, 92, 246, 0.15);
    }
    .card-title { font-size: 16px; font-weight: 800; color: white; margin-bottom: 8px; }
    .card-price { font-size: 28px; font-weight: 900; color: white; margin-bottom: 16px; }
    .card-price span { font-size: 11px; font-weight: 600; color: #475569; }
    .features-list { list-style: none; text-align: left; margin-bottom: 24px; font-size: 11px; color: #94a3b8; }
    .features-list li { margin-bottom: 10px; display: flex; align-items: center; gap: 8px; }
    
    .btn-buy {
      width: 100%;
      padding: 12px;
      background: linear-gradient(135deg, #06b6d4, #4f46e5);
      color: white;
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1px;
      border: none;
      border-radius: 12px;
      cursor: pointer;
      text-decoration: none;
      display: block;
      box-shadow: 0 4px 10px rgba(79, 70, 229, 0.2);
    }
    .btn-buy:active { transform: scale(0.98); }

    footer { border-top: 1px solid #0f172a; padding: 24px; text-align: center; font-size: 12px; color: #475569; }
  </style>
</head>
<body>

  <div class="halo"></div>

  <!-- En-tête -->
  <header>
    <a href="/" class="logo-area">
      <img src="/logo.png" id="logo-main-img" onerror="this.style.display='none'; document.getElementById('logo-fallback-box').style.display='flex';" class="logo-img" alt="OMNIX Logo">
      <div id="logo-fallback-box" style="display: none; width: 38px; height: 38px; border-radius: 10px; background: linear-gradient(135deg, #06b6d4, #7c3aed); align-items: center; justify-content: center; font-weight: 900; color: white; font-size: 18px; box-shadow: 0 4px 12px rgba(6, 182, 212, 0.2);">O</div>
