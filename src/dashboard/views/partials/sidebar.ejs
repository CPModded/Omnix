// CORRECTIF IOS/SAFARI : Ajoute dynamiquement l'attribut Secure sur HTTPS
  function setToken(value) {
    try {
      localStorage.setItem('jwt_token', value);
    } catch (e) {
      console.error("Local storage non disponible:", e);
    }
    const isSecure = window.location.protocol === 'https:';
    document.cookie = `jwt_token=${value}; path=/; max-age=604800; SameSite=Lax${isSecure ? '; Secure' : ''}`;
  }